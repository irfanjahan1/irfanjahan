let aDragWord = null;
let aFill1Answers = new Array(10).fill(null);
let aFill2Answers = new Array(10).fill(null);

let aScore=0;
function aBuild(){
  document.getElementById('a-vocab-sec').innerHTML='';
  document.getElementById('a-trans-sec').innerHTML='';
  document.getElementById('a-fill1-sec').innerHTML='';
  document.getElementById('a-fill2-sec').innerHTML='';
  aFill1Answers = new Array(10).fill(null);
  aFill2Answers = new Array(10).fill(null);

  /* Section 1 — Vocab MCQ */
  aVocab.forEach((d,i)=>{
    document.getElementById('a-vocab-sec').innerHTML+=`
    <div class="a-q-box" id="av-${i}">
      <div class="a-q-row">
        <span class="a-q-text">${i+1}. ${d.q}</span>
        <div class="a-opt-row">${d.opts.map((o,idx)=>`<button class="a-opt-btn a-urdu" onclick="aChk(this,${idx},${d.c},'av-${i}')">${String.fromCharCode(97+idx)}) ${o}</button>`).join('')}</div>
      </div>
    </div>`;
  });

  /* Section 2 — Translation MCQ */
  aTrans.forEach((d,i)=>{
    document.getElementById('a-trans-sec').innerHTML+=`
    <div class="a-q-box" id="at-${i}">
      <span class="a-q-text" style="display:block;margin-bottom:6px;font-size:0.93rem;direction:rtl;font-family:'Noto Nastaliq Urdu',serif;">${i+1}. ${d.q}</span>
      <div class="a-opt-row">${d.opts.map((o,idx)=>`<button class="a-opt-btn" style="font-size:0.78rem;text-align:left;" onclick="aChk(this,${idx},${d.c},'at-${i}')">${String.fromCharCode(97+idx)}) ${o}</button>`).join('')}</div>
    </div>`;
  });

  /* Section 3 — Fill 1 */
  buildFill('a-fill1-sec', aFill1, 1);

  /* Section 4 — Fill 2 */
  buildFill('a-fill2-sec', aFill2, 2);
}

function buildFill(containerId, data, num) {
  const container = document.getElementById(containerId);
  const answers = num===1 ? aFill1Answers : aFill2Answers;

  /* Word bank */
  let bankHTML = `<div id="a-bank-${num}" style="display:flex;flex-wrap:wrap;gap:7px;padding:12px;background:rgba(40,168,112,0.08);border-radius:10px;margin:8px 12px 14px;border:1px dashed rgba(40,168,112,0.3);">`;
  data.bank.forEach(w => {
    bankHTML += `<span class="a-drag-word" draggable="true" id="aw-${num}-${w}"
      ondragstart="aDragStart(event,'${w}')"
      onclick="aWordClick(this,'${w}',${num})"
      style="background:#fff;border:1.5px solid var(--green-400);color:var(--text-dark);padding:5px 12px;border-radius:20px;font-size:0.82rem;font-weight:700;cursor:pointer;user-select:none;transition:0.15s;">${w}</span>`;
  });
  bankHTML += `</div>`;

  /* Paragraph with blanks */
  let paraHTML = `<div style="background:#fff;border-radius:12px;padding:14px 16px;margin:0 12px 8px;font-size:0.88rem;font-weight:600;color:var(--text-dark);line-height:2.4;border:1px solid rgba(40,168,112,0.15);">`;
  data.para.forEach((seg, i) => {
    paraHTML += `${seg.before}<span class="a-blank" id="ab-${num}-${i}"
      ondragover="event.preventDefault()"
      ondrop="aDrop(event,${num},${i})"
      onclick="aBlankClick(this,${num},${i})"
      style="display:inline-block;min-width:55px;text-align:center;padding:5px 12px;margin:0 2px;font-weight:700;cursor:pointer;border-radius:20px;background:#fff;border:1.5px solid #ccc;color:#333;font-size:0.82rem;line-height:1;vertical-align:middle;"> &nbsp;&nbsp; </span>${seg.after}`;
  });
  paraHTML += `</div>`;

  container.innerHTML = bankHTML + paraHTML;
}

/* drag-and-drop + tap-to-place */
function aDragStart(e, word) { aDragWord = word; }

function aDrop(e, num, idx) {
  e.preventDefault();
  if (!aDragWord) return;
  placeWord(aDragWord, num, idx);
  aDragWord = null;
}

let aSelectedWord = null;
let aSelectedWordEl = null;

function aWordClick(el, word, num) {
  /* toggle selection */
  if (aSelectedWord === word) {
    aSelectedWord = null; aSelectedWordEl = null;
    el.style.background = '#fff'; el.style.borderColor = 'var(--green-400)';
    return;
  }
  /* deselect previous */
  if (aSelectedWordEl) { aSelectedWordEl.style.background='#fff'; aSelectedWordEl.style.borderColor='var(--green-400)'; }
  aSelectedWord = word; aSelectedWordEl = el;
  el.style.background = 'var(--green-100)'; el.style.borderColor = 'var(--green-600)';
}

function aBlankClick(el, num, idx) {
  if (!aSelectedWord) return;
  placeWord(aSelectedWord, num, idx);
  if (aSelectedWordEl) { aSelectedWordEl.style.background='#fff'; aSelectedWordEl.style.borderColor='var(--green-400)'; }
  aSelectedWord = null; aSelectedWordEl = null;
}

function placeWord(word, num, idx) {
  const answers = num===1 ? aFill1Answers : aFill2Answers;
  const data    = num===1 ? aFill1        : aFill2;

  /* if word already placed somewhere, clear that blank */
  const prev = answers.indexOf(word);
  if (prev !== -1) {
    answers[prev] = null;
    document.getElementById(`ab-${num}-${prev}`).innerHTML = ' &nbsp;&nbsp; ';
    document.getElementById(`ab-${num}-${prev}`).style.color = '#333';
  }

  /* if blank already had a word, return it to bank visually */
  const old = answers[idx];
  if (old) {
    const oldEl = document.getElementById(`aw-${num}-${old}`);
    if (oldEl) { oldEl.style.display=''; }
  }

  answers[idx] = word;
  const blank = document.getElementById(`ab-${num}-${idx}`);
  blank.textContent = word;
  blank.style.color = 'var(--text-dark)';

  /* hide used word from bank */
  const wordEl = document.getElementById(`aw-${num}-${word}`);
  if (wordEl) wordEl.style.display = 'none';
}

function aChk(btn,sel,cor,qid){
  const p=document.getElementById(qid);
  if(p.classList.contains('done'))return;
  p.classList.add('done');
  if(sel===cor){aScore++;btn.classList.add('correct');}
  else{btn.classList.add('wrong');p.querySelectorAll('.a-opt-btn')[cor].classList.add('correct');}
}

function aSubmit(){
  /* score fill-in-the-blank */
  [aFill1, aFill2].forEach((data, fi) => {
    const num = fi+1;
    const answers = fi===0 ? aFill1Answers : aFill2Answers;
    answers.forEach((ans, i) => {
      const blank = document.getElementById(`ab-${num}-${i}`);
      if (ans === data.blanks[i]) {
        aScore++;
      } else {
        if(blank){
          blank.textContent = (ans||'—');
        }
      }
    });
  });

  document.getElementById('a-quiz').style.display='none';
  document.getElementById('a-result').style.display='block';
  document.getElementById('a-bottom-nav').style.display='flex';
  const total = aVocab.length + aTrans.length + aFill1.blanks.length + aFill2.blanks.length;
  document.getElementById('a-score').textContent=`${aScore}/${total}`;
  let r='';
  if(aScore===total)r="Perfect! You are a Master! 🌟";
  else if(aScore>=total*0.83)r="Excellent Work! Keep it up! 👏";
  else if(aScore>=total*0.67)r="Good Job! You're doing well. 👍";
  else if(aScore>=total*0.5)r="Keep Practicing! You're getting there. 💪";
  else r="Don't give up! Review the lessons and try again. 📚";
  document.getElementById('a-remarks').textContent=r;
  const end=Date.now()+3000;
  (function frame(){
    confetti({particleCount:3,angle:60,spread:55,origin:{x:0},colors:['#1a4731','#40916c','#b7e4c7']});
    confetti({particleCount:3,angle:120,spread:55,origin:{x:1},colors:['#1a4731','#40916c','#b7e4c7']});
    if(Date.now()<end)requestAnimationFrame(frame);
  }());
}

function aRetake(){
  aScore=0;
  document.getElementById('a-result').style.display='none';
  document.getElementById('a-bottom-nav').style.display='none';
  document.getElementById('a-quiz').style.display='block';
  aBuild(); window.scrollTo(0,0);
}

