.a-bank-word.selected { background:var(--green-600); color:#fff; border-color:var(--green-600); }
.a-para-text { font-size:0.9rem; line-height:2.1; color:var(--text-dark); font-weight:600; }
.a-blank { display:inline-block; min-width:80px; border-bottom:2.5px solid var(--green-400); margin:0 3px; padding:1px 6px; cursor:pointer; color:var(--green-700); font-weight:800; font-size:0.88rem; text-align:center; border-radius:3px 3px 0 0; transition:background 0.15s; vertical-align:bottom; }
.a-blank:hover { background:rgba(40,168,112,0.08); }
.a-blank.filled { background:rgba(40,168,112,0.10); color:var(--green-800); }
.a-blank.correct-fill { background:#d4edda !important; border-color:#28a745 !important; color:#155724 !important; }
.a-blank.wrong-fill { background:#f8d7da !important; border-color:#dc3545 !important; color:#721c24 !important; }

