}
.p-action-btn:hover { background:var(--green-500); }
.p-action-btn.alt { background:#2d6a4f; }

/* ═══════════════════════════════════════════════════
   PAGE 6 — CONVERSATION (Chat Phone UI)
═══════════════════════════════════════════════════ */
#page-convo {
  background: #6BBF6B;
  padding-top: var(--dash-h);
  display: flex; flex-direction: column; align-items: center;
  overflow-x: hidden;
}

.c-main { width:100%; max-width:600px; padding:0 12px 40px; display:flex; flex-direction:column; align-items:center; margin-top:20px; }

.c-topic { font-family:'Cinzel', serif; font-size:1.6rem; color:var(--green-900); margin-bottom:14px; letter-spacing:.05em; font-weight:800; }

.c-progress-wrap { width:100%; height:8px; background:rgba(255,255,255,0.1); border-radius:10px; margin-bottom:24px; overflow:hidden; border:1px solid rgba(40,168,112,0.2); }
.c-progress-fill { height:100%; background:linear-gradient(90deg,var(--gold-mid),var(--gold)); width:0%; transition:width .4s ease; }

.phone-wrapper { position:relative; width:100%; display:flex; justify-content:center; align-items:center; margin-bottom:28px; }
.mobile-phone {
  width:100%; max-width:318px; height:580px;
  background: #081f16;
  border: 8px solid #2a2a2a;
  border-radius: 40px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.6), inset 0 0 10px rgba(0,0,0,0.5);
  position:relative; overflow:hidden;
  display:flex; flex-direction:column; z-index:5;
}
.phone-nav-btn {
  position:absolute; top:50%; transform:translateY(-50%);
  width:48px; height:48px;
  background:var(--green-400); border:none; border-radius:50%;
  color:white; display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:var(--transition);
  box-shadow:0 6px 15px rgba(0,0,0,0.4); z-index:10;
}
.phone-nav-btn:disabled { opacity:0; pointer-events:none; }
.phone-nav-btn:hover { background:var(--green-300); transform:translateY(-50%) scale(1.1); }
#c-prevBtn { left:-10px; }
#c-nextBtn { right:-10px; }
@media(min-width:500px){ #c-prevBtn{left:40px;} #c-nextBtn{right:40px;} }

.phone-notch { position:absolute; top:0; left:50%; transform:translateX(-50%); width:150px; height:24px; background:#2a2a2a; border-bottom-left-radius:20px; border-bottom-right-radius:20px; z-index:10; }
.status-bar { height:44px; padding:0 24px; display:flex; justify-content:space-between; align-items:center; font-size:0.72rem; font-weight:700; color:#fff; z-index:5; margin-top:5px; }
.chat-head { padding:10px 18px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; gap:10px; }
.ch-avatar { width:34px; height:34px; background:var(--green-700); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.95rem; border:1px solid var(--green-400); }
.ch-info h4 { font-size:0.82rem; color:#fff; }
.ch-info p  { font-size:0.62rem; color:var(--green-300); }

.chat-window { flex:1; padding:18px 14px; display:flex; flex-direction:column; gap:18px; background:rgba(255,255,255,0.02); position:relative; overflow:hidden; }
.start-overlay { position:absolute; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; z-index:30; background:rgba(0,0,0,0.2); }
.start-chat-btn { background:var(--gold); color:var(--green-900); padding:12px 28px; border-radius:var(--radius-pill); border:none; font-weight:900; cursor:pointer; }

.msg-row { display:flex; width:100%; }
.msg-row.left { justify-content:flex-start; }
.msg-row.right { justify-content:flex-end; }
.bubble {
  max-width:86%; padding:11px 15px;
  border-radius:18px; font-size:0.93rem; line-height:1.4;
  min-height:56px; display:flex; flex-direction:column; justify-content:center;
}
.left .bubble { background:var(--green-700); color:#fff; border-bottom-left-radius:4px; }
.right .bubble { background:var(--gold); color:#1a0f00; border-bottom-right-radius:4px; direction:ltr; text-align:left; }
.bubble .ur-sub { margin-top:4px; font-size:0.72rem; opacity:.85; font-family:'Noto Nastaliq Urdu',serif; direction:rtl; text-align:right; font-weight:700; }
.typing-dots { display:inline-flex; gap:4px; padding:5px 0; }
.typing-dots span { width:6px; height:6px; background:#fff; border-radius:50%; animation:wave 1.2s infinite ease-in-out; opacity:.6; }
.right .typing-dots span { background:#1a0f00; }
.typing-dots span:nth-child(2){animation-delay:.2s;} .typing-dots span:nth-child(3){animation-delay:.4s;}
@keyframes wave { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-6px)} }
.fade-in { animation:fadeInMsg .5s ease forwards; opacity:0; }
@keyframes fadeInMsg { from{opacity:0;transform:translateY(5px)} to{opacity:1;transform:translateY(0)} }

.chat-input-bar { padding:14px; display:flex; align-items:center; gap:8px; border-top:1px solid rgba(255,255,255,0.05); }
.fake-input { flex:1; height:36px; background:rgba(255,255,255,0.1); border-radius:18px; padding:0 14px; display:flex; align-items:center; color:rgba(255,255,255,0.4); font-size:0.78rem; }
.mic-btn { width:36px; height:36px; background:var(--green-400); border-radius:50%; display:flex; align-items:center; justify-content:center; }

.c-wave-anim {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  padding: 18px 0 10px;
}
.c-wave-anim span {
  display: inline-block;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--gold);
  animation: chatWave 1.0s infinite ease-in-out;
  opacity: 0.85;
}
.c-wave-anim span:nth-child(1) { animation-delay: 0s; }
.c-wave-anim span:nth-child(2) { animation-delay: 0.12s; }
.c-wave-anim span:nth-child(3) { animation-delay: 0.24s; }
.c-wave-anim span:nth-child(4) { animation-delay: 0.36s; }
.c-wave-anim span:nth-child(5) { animation-delay: 0.48s; }
@keyframes chatWave {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.6; }
  30% { transform: translateY(-10px); opacity: 1; }
}


.c-action-btn { flex:1; text-decoration:none; background:rgba(200,168,75,0.14); border:1.5px solid var(--gold-mid); color:var(--gold); padding:12px; border-radius:var(--radius-pill); font-weight:800; text-align:center; font-size:0.85rem; cursor:pointer; transition:var(--transition); }
