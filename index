.a-fill-title { font-weight:900; font-size:0.88rem; color:var(--green-700); margin-bottom:10px; letter-spacing:.3px; text-transform:uppercase; }
.a-word-bank { display:flex; flex-wrap:wrap; gap:7px; margin-bottom:12px; padding:10px; background:rgba(40,168,112,0.07); border-radius:8px; border:1px dashed rgba(40,168,112,0.3); }
.a-bank-word { background:#fff; border:1.5px solid var(--green-300); color:var(--green-800); padding:4px 11px; border-radius:20px; font-weight:800; font-size:0.82rem; cursor:pointer; transition:var(--transition); font-family:'Nunito',sans-serif; }
.a-bank-word:hover { background:var(--green-50); }
