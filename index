<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>English Mastery Course by Irfan Jahan</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;800&family=Montserrat:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,600;0,700;0,900;1,700&family=Nunito:wght@400;500;600;700;800;900&family=Noto+Nastaliq+Urdu:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<style>
/* ═══════════════════════════════════════════════════
   DESIGN SYSTEM — UNIFIED TOKEN SET
═══════════════════════════════════════════════════ */
:root {
  --green-900: #061710;
  --green-800: #0a2e1a;
  --green-700: #134d2c;
  --green-600: #1a6b3c;
  --green-500: #22883f;
  --green-400: #28a870;
  --green-300: #3dbd5a;
  --green-200: #74c69d;
  --green-100: #b7e4c7;
  --green-50:  #e6f9ec;
  --gold:      #f4d03f;
  --gold-mid:  #c8a84b;
  --gold-dark: #d4ac0d;
  --white:     #f9fef9;
  --off-white: #f7faf8;
  --text-dark: #0d1f13;
  --text-mid:  #2d5a3d;
  --text-muted:#5a8a6a;
  --shadow-lg: 0 20px 80px rgba(10,46,26,0.28);
  --shadow-md: 0 8px 40px rgba(0,0,0,0.30);
  --radius-xl: 28px;
  --radius-lg: 20px;
  --radius-md: 12px;
  --radius-sm: 8px;
  --radius-pill: 999px;
  --dash-h:    48px;
  --transition: 0.22s cubic-bezier(.4,0,.2,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }

/* ── Montserrat: all headings & buttons ── */
h1, h2, h3, h4, h5, h6,
button, .ud-btn, .cta-btn, .reg-submit, .reg-photo-btn,
.v-start-btn, .s-start-btn, .p-start-btn, .start-chat-btn,
.t-start-btn, .t-show-btn, .t-nav-btn, .nav-btn-card,
.btn-next-sec, .p-action-btn, .s-btn, .c-action-btn,
.chunk-btn, .wa-highlight, .retake-btn, .a-opt-btn,
.week-pill, .pn-btn, .sb-btn, .crop-btn, .photo-source-btn,
#ud-logout-btn, #startBtn {
  font-family: 'Montserrat', sans-serif !important;
}

body {
  font-family: 'Nunito', sans-serif;
  background: #6BBF6B;
  color: var(--white);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ═══════════════════════════════════════════════════
   UNIVERSAL DASHBOARD  (shown on inner pages)
═══════════════════════════════════════════════════ */
#universal-dash {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--dash-h);
  background: linear-gradient(90deg, var(--green-900) 0%, var(--green-800) 60%, var(--green-700) 100%);
  align-items: center;
  gap: 10px;
  padding: 0 14px;
  z-index: 1000;
  box-shadow: 0 4px 24px rgba(0,0,0,0.45);
  flex-wrap: nowrap;
}
#universal-dash.visible { display: flex; }

#ud-left { display: flex; align-items: center; gap: 10px; flex-shrink: 0; min-width: 0; }

#ud-home {
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px;
  border-radius: var(--radius-sm);
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.18);
  color: var(--white);
  cursor: pointer;
  flex-shrink: 0;
  transition: var(--transition);
}
#ud-home:hover { background: rgba(255,255,255,0.22); transform: scale(1.08); }
#ud-home svg { width: 17px; height: 17px; }

#ud-title {
  font-family: 'Cinzel', serif;
  font-size: 13px; font-weight: 700;
  color: rgba(255,255,255,0.92);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 260px;
  letter-spacing: .3px;
}

/* User info in dashboard */
#ud-user-info {
  display:flex;align-items:center;gap:8px;flex-shrink:0;
  margin-left:auto;
  height:36px;
}
#ud-user-avatar-wrap {
  width:36px;height:36px;border-radius:50%;overflow:hidden;
  border:2px solid rgba(40,168,112,0.5);
  background:rgba(255,255,255,0.08);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
#ud-user-avatar { width:100%;height:100%;object-fit:cover;display:none; }
#ud-avatar-placeholder { font-size:1rem;opacity:0.5;line-height:1; }
#ud-user-name {
  font-size:0.78rem;font-weight:800;
  color:rgba(255,255,255,0.85);
  white-space:nowrap;max-width:120px;
  overflow:hidden;text-overflow:ellipsis;
  line-height:1;
}

#ud-spacer { flex: 1; }

#ud-nav { display: flex; gap: 5px; flex-shrink: 0; flex-wrap: wrap; justify-content: flex-end; }

.ud-btn {
  font-family: 'Nunito', sans-serif;
  font-size: 10px; font-weight: 700;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.09);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: var(--radius-sm);
  padding: 6px 10px;
  cursor: pointer;
  white-space: nowrap;
  transition: var(--transition);
}
.ud-btn:hover, .ud-btn.active {
  background: var(--green-400);
  border-color: var(--green-300);
  color: #fff;
  transform: translateY(-1px);
}

/* ═══════════════════════════════════════════════════
   SHARED UTILITIES
═══════════════════════════════════════════════════ */
.page { display: none !important; width: 100%; min-height: 100vh; }
.page.active { display: block !important; }
/* Restore flex layout for pages that use it */
#page-landing.active,
#page-vocab.active,
#page-sentences.active,
#page-convo.active,
#page-test.active { display: flex !important; }

.with-dash { padding-top: var(--dash-h); }

/* Space for fixed bottom nav strip on all inner pages */
#page-day1, #page-vocab, #page-sentences, #page-practice,
#page-convo, #page-test, #page-assess, #page-challenge {
  padding-bottom: 72px;
}

/* ═══════════════════════════════════════════════════
   PAGE 0 — LANDING
═══════════════════════════════════════════════════ */
#page-landing {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: #6BBF6B;
  padding: 2rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
#page-landing::before {
  content:'';
  position:absolute; inset:0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 30px 30px;
  pointer-events:none;
}

.landing-badge {
  display: inline-block;
  background: rgba(244,208,63,0.12);
  border: 1px solid rgba(244,208,63,0.35);
  color: var(--gold);
  font-size: 0.72rem; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 6px 16px; border-radius: var(--radius-pill);
  margin-bottom: 1.5rem;
}

.landing-title-wrap {
  margin-bottom: 1.6rem;
  text-align: center;
}
.landing-title-main {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.7rem, 5vw, 3rem);
  font-weight: 800;
  color: var(--green-900);
  letter-spacing: -0.5px;
  line-height: 1.12;
  text-shadow: 0 2px 8px rgba(0,0,0,0.12);
  margin-bottom: 0.55rem;
}
.landing-title-by {
  font-family: 'Cinzel', serif;
  font-style: normal;
  font-size: clamp(0.9rem, 2.2vw, 1.1rem);
  color: var(--green-700);
  font-weight: 600;
  letter-spacing: 2px;
}

.landing-sub {
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: rgba(255,255,255,0.72);
  max-width: 480px; margin: 0 auto 2.5rem;
  line-height: 1.7;
}

.landing-features {
  display: flex; flex-wrap: wrap; gap: 1rem;
  justify-content: center; margin-bottom: 2.5rem;
}
.feat-chip {
  background: rgba(40,168,112,0.15);
  border: 1px solid rgba(40,168,112,0.3);
  color: var(--green-100);
  font-size: 0.8rem; font-weight: 700;
  padding: 7px 15px; border-radius: var(--radius-pill);
}

#startBtn {
  padding: 1.1rem 3.5rem;
  font-family: 'Cinzel', serif;
  font-size: 1.1rem; font-weight: 800;
  color: var(--green-900);
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  border: none; border-radius: var(--radius-pill);
  cursor: pointer;
  box-shadow: 0 8px 32px rgba(244,208,63,0.38);
  transition: var(--transition);
  letter-spacing: .5px;
}
#startBtn:hover { transform: scale(1.06); box-shadow: 0 12px 40px rgba(244,208,63,0.5); }

.landing-wa {
  margin-top: 2rem;
  font-size: 0.8rem; color: rgba(255,255,255,0.4);
}
.landing-wa a { color: #25d366; text-decoration: none; font-weight: 700; }

/* ── View Details button on landing ── */
.view-details-btn {
  background: rgba(255,255,255,0.55);
  border: 1.5px solid rgba(255,255,255,0.85);
  color: #083318;
  font-family: 'Nunito', sans-serif;
  font-size: 0.78rem;
  font-weight: 800;
  padding: 7px 20px;
  border-radius: var(--radius-pill);
  cursor: pointer;
  margin-bottom: 14px;
  letter-spacing: .3px;
  transition: var(--transition);
}
.view-details-btn:hover {
  background: rgba(255,255,255,0.85);
  transform: translateY(-1px);
}

/* ── Course Details Popup ── */
#course-details-modal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99998;
  background: rgba(6,23,16,0.72);
  backdrop-filter: blur(4px);
  align-items: center;
  justify-content: center;
  padding: 20px;
}
#course-details-modal.open { display: flex; }
.cdm-box {
  background: #fff;
  border-radius: var(--radius-xl);
  max-width: 520px;
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 24px 80px rgba(0,0,0,0.45);
  position: relative;
  animation: cdmIn 0.28s cubic-bezier(.4,0,.2,1) both;
}
@keyframes cdmIn {
  from { opacity:0; transform: translateY(18px) scale(0.97); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}
/* Fixed top bar — never scrolls */
.cdm-top-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px 16px 10px;
  border-bottom: 1px solid rgba(40,168,112,0.12);
  background: #fff;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}
.cdm-close {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: var(--green-800);
  border: 2.5px solid var(--green-600);
  color: #fff;
  font-size: 1.1rem; font-weight: 900;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.18s, transform 0.18s;
  flex-shrink: 0;
}
.cdm-close:hover { background: var(--green-600); transform: scale(1.1); }
/* Scrollable content area */
.cdm-scroll {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: none;
  padding: 22px 36px 20px;
}
.cdm-scroll::-webkit-scrollbar { display: none; }
/* Fixed bottom bar with arrow button — never scrolls */
.cdm-bottom-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px 16px 14px;
  background: #fff;
  border-top: 1px solid rgba(40,168,112,0.12);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}
.cdm-arrow-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--green-700);
  border: none;
  color: #fff;
  font-size: 1rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.18s, transform 0.18s;
}
.cdm-arrow-btn:hover { background: var(--green-500); transform: scale(1.1); }
.cdm-title {
  font-family: 'Cinzel', serif;
  font-size: 1.25rem; font-weight: 800;
  color: var(--green-800);
  text-align: center; margin-bottom: 18px; letter-spacing: .4px;
}
.cdm-body {
  font-family: 'Nunito', sans-serif;
  font-size: 0.92rem; color: #1a3a25; line-height: 1.75;
}
.cdm-body p { margin-bottom: 12px; }
.cdm-sub-heading { font-weight: 900; color: var(--green-700); margin-bottom: 8px !important; }
.cdm-body ul { list-style: none; padding: 0; margin: 0 0 18px; }
.cdm-body ul li {
  padding: 7px 0 7px 28px; position: relative;
  border-bottom: 1px solid rgba(40,168,112,0.1); font-weight: 700;
}
.cdm-body ul li:last-child { border-bottom: none; }
.cdm-body ul li::before { content:'✓'; position:absolute; left:0; color:var(--green-500); font-weight:900; }
.cdm-divider {
  border: none;
  border-top: 1.5px solid rgba(40,168,112,0.22);
  margin: 18px 0 12px;
}
.cdm-copyright {
  text-align: center;
  font-family: 'Nunito', sans-serif;
  font-size: 0.75rem;
  color: var(--text-muted);
  font-weight: 700;
  letter-spacing: .3px;
  padding-bottom: 4px;
}

/* Welcome to + contact info on landing */
.landing-welcome-to {
  font-family: 'Cinzel', serif;
  font-size: clamp(0.85rem, 2vw, 1rem);
  font-weight: 600;
  color: var(--green-700);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 0.3rem;
}
.landing-contact-info {
  margin-top: 1.8rem;
  text-align: center;
  font-size: 0.8rem;
  color: #083318;
  line-height: 2;
}
.landing-contact-line {
  display: flex; align-items: center; justify-content: center; gap: 4px;
  font-weight: 600;
}
.landing-contact-link {
  color: #145c35; text-decoration: none; font-weight: 700;
}
.landing-contact-link:hover { text-decoration: underline; }
.landing-copy-btn {
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(0,0,0,0.12);
  border-radius: 5px;
  cursor: pointer;
  font-size: 0.65rem;
  padding: 1px 5px;
  line-height: 1.4;
  height: 1.4em;
  display: inline-flex; align-items: center; justify-content: center;
  transition: background 0.15s;
  vertical-align: middle;
}
.landing-copy-btn:hover { background: rgba(255,255,255,0.85); }

/* ═══════════════════════════════════════════════════
   PAGE 1 — COURSE INDEX (60-day grid)
═══════════════════════════════════════════════════ */
#page-course {
  background: #6BBF6B;
}

.course-inner { max-width: 940px; margin: 0 auto; padding: 1.5rem; }

.course-welcome {
  text-align: center;
  padding: 1.2rem 0 0.6rem;
}
.course-welcome-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1rem, 3.5vw, 1.5rem);
  font-weight: 800;
  color: var(--green-900);
  letter-spacing: .5px;
  margin-bottom: 1.1rem;
  text-shadow: 0 1px 4px rgba(0,0,0,0.1);
}
.course-progress-wrap {
  max-width: 100%;
  margin: 0 auto 1.5rem;
}
.course-progress-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 7px;
}
.course-progress-label {
  font-size: 0.75rem; font-weight: 800;
  color: var(--green-100);
  letter-spacing: .3px;
}
.course-progress-count {
  font-size: 0.75rem; font-weight: 800;
  color: var(--gold-mid);
}
.course-progress-track {
  width: 100%; height: 10px;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-pill);
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
}
.course-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22883f 0%, #28a870 40%, #f4d03f 80%, #f59e0b 100%);
  border-radius: var(--radius-pill);
  transition: width 0.6s cubic-bezier(.4,0,.2,1);
  box-shadow: 0 0 10px rgba(244,208,63,0.3);
}

.weeks-nav {
  display: flex; flex-wrap: nowrap;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
  justify-content: space-between;
}
.weeks-nav::-webkit-scrollbar { display: none; }
.week-pill {
  padding: 0.38rem 0.9rem;
  border-radius: var(--radius-pill);
  border: 1px solid rgba(40,168,112,0.35);
  background: transparent;
  color: var(--green-100);
  font-family: 'Nunito', sans-serif;
  font-size: 0.72rem; font-weight: 800;
  cursor: pointer; transition: var(--transition);
  flex: 1;
  text-align: center;
}
.week-pill:hover, .week-pill.active { background: var(--green-400); border-color: var(--green-300); color: #fff; }

.week-label {
  grid-column: 1/-1;
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem; color: var(--gold);
  margin: 1rem 0 0.5rem;
  border-left: 4px solid var(--green-400);
  padding-left: 10px;
  display: none;
}
.week-label.visible { display: block; }

.days-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.day-card, .weekly-review {
  background: rgba(20,90,50,0.42);
  border: 1px solid rgba(40,168,112,0.2);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: var(--transition);
  display: none;
  min-height: 64px;
}
.day-card.visible, .weekly-review.visible { display: block; }
.day-card:hover { border-color: var(--gold-mid); background: rgba(30,132,73,0.28); transform: translateY(-2px); }
.weekly-review:hover { border-color: var(--green-300); background: rgba(40,168,112,0.2); transform: translateY(-2px); }

.day-header {
  display: flex; align-items: center;
  gap: 0.8rem; padding: 0.8rem;
}
.day-badge, .week-badge {
  background: var(--green-400);
  min-width: 42px; height: 42px;
  border-radius: var(--radius-sm);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  font-size: 0.48rem; font-weight: 800; color: #fff;
  flex-shrink: 0;
}
.week-badge { background: var(--gold-mid); }
.day-badge strong, .week-badge strong { font-size: 1.05rem; }
.day-topic, .review-topic {
  font-size: 0.82rem; font-weight: 700;
  line-height: 1.25; text-align: left;
}

.course-footer {
  text-align: center; padding: 3rem 2rem;
  background: #061710;
  border-top: 1px solid rgba(40,168,112,0.12);
}
.wa-highlight {
  display: inline-block;
  background: #25d366; color: white;
  padding: 9px 22px; border-radius: var(--radius-pill);
  font-weight: 800; margin-bottom: 12px;
  text-decoration: none;
  box-shadow: 0 4px 18px rgba(37,211,102,0.3);
  transition: var(--transition);
}
.wa-highlight:hover { transform: scale(1.04); }

/* ═══════════════════════════════════════════════════
   PAGE 2 — DAY 1 INTRO
═══════════════════════════════════════════════════ */
#page-day1 {
  background: #6BBF6B;
  color: var(--text-dark);
}
#page-day1 main {
  min-height: calc(100vh - var(--dash-h) - 80px);
  display: flex; align-items: center; justify-content: center;
  padding: 24px 20px 36px;
}
.intro-card {
  background: #fff;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  max-width: 680px; width: 100%;
  padding: 44px 52px 48px;
  text-align: center;
  position: relative; overflow: hidden;
  animation: cardIn 0.7s cubic-bezier(.4,0,.2,1) both;
}
@keyframes cardIn {
  from { opacity:0; transform: translateY(28px) scale(0.98); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}
.intro-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:5px;
  background: linear-gradient(90deg, var(--green-400), var(--green-200), var(--green-400));
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}
.intro-card h1 {
  font-size: 28px; font-weight: 900;
  color: var(--text-dark); line-height: 1.3;
  margin-bottom: 8px; letter-spacing: -0.02em;
}
.intro-card h1 span { color: var(--green-500); }
.intro-divider {
  width: 60px; height: 4px;
  background: linear-gradient(90deg, var(--green-300), var(--green-200));
  border-radius: 99px; margin: 14px auto 26px;
}
.intro-body {
  font-size: 16px; line-height: 1.8;
  color: var(--text-mid); font-weight: 500;
  margin-bottom: 30px; text-align: left;
}
.intro-body ul { list-style: none; padding-left: 0; }
.intro-body li {
  margin-bottom: 12px; padding-left: 26px; position: relative;
}
