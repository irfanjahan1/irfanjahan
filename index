}
.t-start-screen { flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; gap:20px; }
.t-content { display:none; flex-direction:column; gap:10px; flex:1; justify-content:center; align-items:center; }
.t-congrats { display:none; flex-direction:column; justify-content:center; align-items:center; gap:14px; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:100%; animation:congratsIn .8s ease forwards; }
@keyframes congratsIn { from{opacity:0;transform:translate(-50%,-60%)} to{opacity:1;transform:translate(-50%,-50%)} }
.congrats-title { font-family:'Playfair Display',serif; font-size:2.4rem; color:var(--gold); }
.congrats-sub { font-size:1.15rem; color:#fff; }

.t-question { cursor:pointer; padding:8px; }
.t-q-text { font-size:1.75rem; font-weight:800; color:#fff; }
.t-reveal { display:none; flex-direction:column; gap:14px; margin-top:4px; animation:fadeInMsg .4s ease; }
.t-answer-box { padding:12px; border-bottom:1px solid rgba(200,168,75,0.2); }
.t-a-text { font-size:1.35rem; font-weight:700; color:var(--gold); }

.t-ctrl { display:flex; justify-content:center; align-items:center; gap:12px; padding-top:14px; margin-top:auto; }
.t-nav-btn { background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; padding:10px 15px; border-radius:var(--radius-md); cursor:pointer; font-weight:700; font-size:0.85rem; flex:1; max-width:100px; font-family:'Nunito',sans-serif; }
.t-show-btn, .t-start-btn { background:var(--gold); color:#1a0f00; border:none; padding:12px 26px; border-radius:var(--radius-pill); font-weight:900; cursor:pointer; box-shadow:0 4px 15px rgba(0,0,0,0.2); transition:var(--transition); font-family:'Nunito',sans-serif; }
.t-start-btn { font-size:1.1rem; padding:18px 42px; }
.t-show-btn { flex:2; max-width:165px; font-size:0.9rem; }
.t-nav-btn:disabled { opacity:0.3; }
.t-nav-btn:hover:not(:disabled), .t-show-btn:hover, .t-start-btn:hover { transform:translateY(-1px); }

.t-lesson-group { display:flex; gap:10px; margin-top:20px; }
.t-lesson-link { text-decoration:none; flex:1; background:var(--green-400); color:#fff; padding:14px; border-radius:var(--radius-lg); font-weight:900; text-align:center; font-size:0.95rem; transition:var(--transition); cursor:pointer; }
