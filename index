let sIdx=0;
let sSpeaking = false;
function sToggleStartStop() {
  const btn = document.getElementById('s-speak');
  if (!document.getElementById('s-start-overlay').style.display || document.getElementById('s-start-overlay').style.display !== 'none') {
    // First time: start
    sStart();
    return;
  }
  if (sSpeaking) {
    synth.cancel();
    sSpeaking = false;
    btn.textContent = '▶ Start';
  } else {
    sSpeaking = true;
    btn.textContent = '⏹ Stop';
    speak(phrases[sIdx].en);
  }
}
function sStart() {
  document.getElementById('s-start-overlay').style.display = 'none';
  document.getElementById('s-prev').style.visibility = 'visible';
  document.getElementById('s-next').style.visibility = 'visible';
  sSpeaking = true;
  document.getElementById('s-speak').textContent = '⏹ Stop';
  sRender(true);
}
function sRender(speak_=false) {
  const p=phrases[sIdx];
  document.getElementById('s-en').textContent=p.en;
  document.getElementById('s-ur').innerHTML=`<strong>${p.ur}</strong>`;
  document.getElementById('s-cat').textContent=p.cat;
  document.getElementById('s-counter').textContent=`${sIdx+1} / ${phrases.length}`;
  document.getElementById('s-prog').style.width=`${((sIdx+1)/phrases.length)*100}%`;
  document.getElementById('s-prev').disabled=sIdx===0;
  const sNextBtn = document.getElementById('s-next');
  const speakBtn = document.getElementById('s-speak');
  if (sIdx === phrases.length - 1) {
    sNextBtn.disabled = false;
    sNextBtn.textContent = 'Next ▶';
    sNextBtn.onclick = () => { showPage('practice'); };
    sSpeaking = false;
    speakBtn.textContent = '↺ Start Again';
    speakBtn.onclick = () => {
      sIdx=0; sSpeaking=true; speakBtn.textContent='⏹ Stop';
      speakBtn.onclick = sToggleStartStop;
      const fc=document.getElementById('s-flashcard');
      fc.classList.add('animating');
      setTimeout(()=>{sRender(true);fc.classList.remove('animating');},50);
    };
  } else {
    sNextBtn.disabled = false;
    sNextBtn.textContent = 'Next ▶';
    sNextBtn.onclick = () => sNav(1);
    speakBtn.onclick = sToggleStartStop;
  }
  if(speak_ && sSpeaking) speak(p.en);
}
function sNav(d) {
  sIdx=Math.max(0,Math.min(phrases.length-1,sIdx+d));
  const fc=document.getElementById('s-flashcard');
  fc.classList.add('animating');
  setTimeout(()=>{sRender(true);fc.classList.remove('animating');},50);
}
function sSpeak(){speak(phrases[sIdx].en);}

