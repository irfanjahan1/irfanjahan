function pnUpdateStrip(currentId) {
  const strip = document.getElementById('page-nav-strip');
  const prevBtn = document.getElementById('pn-prev');
  const nextBtn = document.getElementById('pn-next');
  const idx = PN_PAGES.indexOf(currentId);
  if (idx === -1) {
    strip.classList.remove('visible');
    return;
  }
  strip.classList.add('visible');
  // day1 (idx===0) prev goes to course, so enable it
  prevBtn.disabled = false;
  nextBtn.disabled = false;
}

function pnNavigate(dir) {
  synth.cancel();
  const activePage = document.querySelector('.page.active');
  if (!activePage) return;
  const currentId = activePage.id.replace('page-', '');
  const idx = PN_PAGES.indexOf(currentId);
  if (idx === -1) return;
  const newIdx = idx + dir;
  if (newIdx < 0) {
    // Before first inner page → go to course/days index
    showCourse();
    return;
  }
  if (newIdx >= PN_PAGES.length) {
    // Last page next → go to home
    goHome();
    return;
  }
  gotoPage(PN_PAGES[newIdx]);
}

