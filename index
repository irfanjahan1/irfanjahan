.t-progress-wrap { width:100%; height:18px; background:rgba(255,255,255,0.1); border-radius:12px; margin-bottom:24px; overflow:hidden; position:relative; border:1px solid rgba(255,255,255,0.1); }
.t-progress-fill { height:100%; background:linear-gradient(90deg,#28a870,#c8a84b,#f0d98a); width:0%; transition:width .4s ease; }
.t-progress-text { position:absolute; width:100%; text-align:center; font-size:0.68rem; line-height:18px; font-weight:800; color:#fff; text-shadow:0 1px 2px rgba(0,0,0,0.5); }

.t-card {
