.a-opt-row { display:flex; gap:6px; flex-wrap:wrap; margin-top:6px; }
.a-opt-btn { background:#fff; border:1.5px solid var(--green-100); padding:5px 10px; border-radius:8px; cursor:pointer; font-weight:800; font-size:0.84rem; transition:var(--transition); font-family:'Nunito',sans-serif; }
