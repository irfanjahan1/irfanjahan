const P_ROW_H=64;
let pCur=0, pBuilt=false;

function pBuild() {
  if(pBuilt) return; pBuilt=true;
  const track=document.getElementById('tp-track');
  const inner=document.getElementById('tp-inner');
  inner.innerHTML='';
  const spacer=document.createElement('div');
  spacer.style.height=(track.clientHeight/2-P_ROW_H/2)+'px';
  inner.appendChild(spacer.cloneNode());
  chunks.forEach((c,i)=>{
    const row=document.createElement('div');
    row.className='tp-row'+(i===0?' active':'');
    row.innerHTML=`<span class="tp-text">${c.text}</span>`;
    row.onclick=()=>pGo(i);
    inner.appendChild(row);
  });
  inner.appendChild(spacer.cloneNode());
}

let pPlaying = false;

function pGo(idx, sp=true) {
  pCur=Math.max(0,Math.min(chunks.length-1,idx));
  document.querySelectorAll('.tp-row').forEach((r,i)=>r.classList.toggle('active',i===pCur));
  document.getElementById('p-prev').disabled=pCur===0;
  document.getElementById('tp-urdu').textContent=chunks[pCur].urdu;
  document.getElementById('tp-track').scrollTo({top:pCur*P_ROW_H,behavior:'smooth'});
  if(sp && pPlaying) {
    synth.cancel();
    const u = new SpeechSynthesisUtterance(chunks[pCur].text);
    u.lang='en-US'; u.rate=0.85;
    const voices=synth.getVoices();
    u.voice=voices.find(v=>v.lang.includes('en')&&v.name.includes('Google'))||voices[0];
    // after TTS ends, wait 3s for student to repeat, then auto-advance
    u.onend = () => {
      if (!pPlaying) return;
      setTimeout(() => {
        if (!pPlaying) return;
        if (pCur < chunks.length - 1) {
          pGo(pCur + 1, true);
        } else {
          // reached last chunk — stop playing
          pPlaying = false;
          pSetPlayIcon(false);
        }
      }, 1500);
    };
    synth.speak(u);
  } else if (sp && !pPlaying) {
    speak(chunks[pCur].text,'en-US',0.85);
  }
}

function pSetPlayIcon(playing) {
  const btn = document.getElementById('p-play-btn');
  if (!btn) return;
  document.getElementById('p-play-icon').style.display  = playing ? 'none'  : 'block';
  document.getElementById('p-pause-icon').style.display = playing ? 'block' : 'none';
  if (playing) btn.classList.add('playing'); else btn.classList.remove('playing');
}

function pPlayToggle() {
  if (!pPlaying) {
    pPlaying = true;
    pSetPlayIcon(true);
    pGo(pCur, true);
  } else {
    pPlaying = false;
    synth.cancel();
    pSetPlayIcon(false);
  }
}

function pStart() {
  document.getElementById('p-overlay').style.display='none';
  document.getElementById('p-play-btn').style.visibility = 'visible';
  document.getElementById('p-prev').style.visibility = 'visible';
  document.getElementById('p-next').style.visibility = 'visible';
  pBuild();
  pGo(0, false);
}

