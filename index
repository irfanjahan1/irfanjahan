<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>English Mastery Course by Irfan Jahan</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;800&family=Montserrat:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,600;0,700;0,900;1,700&family=Nunito:wght@400;500;600;700;800;900&family=Noto+Nastaliq+Urdu:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<style>
/* ═══════════════════════════════════════════════════
   DESIGN SYSTEM — UNIFIED TOKEN SET
═══════════════════════════════════════════════════ */
:root {
  --green-900: #061710;
  --green-800: #0a2e1a;
  --green-700: #134d2c;
  --green-600: #1a6b3c;
  --green-500: #22883f;
  --green-400: #28a870;
  --green-300: #3dbd5a;
  --green-200: #74c69d;
  --green-100: #b7e4c7;
  --green-50:  #e6f9ec;
  --gold:      #f4d03f;
  --gold-mid:  #c8a84b;
  --gold-dark: #d4ac0d;
  --white:     #f9fef9;
  --off-white: #f7faf8;
  --text-dark: #0d1f13;
  --text-mid:  #2d5a3d;
  --text-muted:#5a8a6a;
  --shadow-lg: 0 20px 80px rgba(10,46,26,0.28);
  --shadow-md: 0 8px 40px rgba(0,0,0,0.30);
  --radius-xl: 28px;
  --radius-lg: 20px;
  --radius-md: 12px;
  --radius-sm: 8px;
  --radius-pill: 999px;
  --dash-h:    48px;
  --transition: 0.22s cubic-bezier(.4,0,.2,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }

/* ── Montserrat: all headings & buttons ── */
h1, h2, h3, h4, h5, h6,
button, .ud-btn, .cta-btn, .reg-submit, .reg-photo-btn,
.v-start-btn, .s-start-btn, .p-start-btn, .start-chat-btn,
.t-start-btn, .t-show-btn, .t-nav-btn, .nav-btn-card,
.btn-next-sec, .p-action-btn, .s-btn, .c-action-btn,
.chunk-btn, .wa-highlight, .retake-btn, .a-opt-btn,
.week-pill, .pn-btn, .sb-btn, .crop-btn, .photo-source-btn,
#ud-logout-btn, #startBtn {
  font-family: 'Montserrat', sans-serif !important;
}

body {
  font-family: 'Nunito', sans-serif;
  background: #6BBF6B;
  color: var(--white);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ═══════════════════════════════════════════════════
   UNIVERSAL DASHBOARD  (shown on inner pages)
═══════════════════════════════════════════════════ */
#universal-dash {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--dash-h);
  background: linear-gradient(90deg, var(--green-900) 0%, var(--green-800) 60%, var(--green-700) 100%);
  align-items: center;
  gap: 10px;
  padding: 0 14px;
  z-index: 1000;
  box-shadow: 0 4px 24px rgba(0,0,0,0.45);
  flex-wrap: nowrap;
}
#universal-dash.visible { display: flex; }

#ud-left { display: flex; align-items: center; gap: 10px; flex-shrink: 0; min-width: 0; }

#ud-home {
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px;
  border-radius: var(--radius-sm);
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.18);
  color: var(--white);
  cursor: pointer;
  flex-shrink: 0;
  transition: var(--transition);
}
#ud-home:hover { background: rgba(255,255,255,0.22); transform: scale(1.08); }
#ud-home svg { width: 17px; height: 17px; }

#ud-title {
  font-family: 'Cinzel', serif;
  font-size: 13px; font-weight: 700;
  color: rgba(255,255,255,0.92);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 260px;
  letter-spacing: .3px;
}

/* User info in dashboard */
#ud-user-info {
  display:flex;align-items:center;gap:8px;flex-shrink:0;
  margin-left:auto;
  height:36px;
}
#ud-user-avatar-wrap {
  width:36px;height:36px;border-radius:50%;overflow:hidden;
  border:2px solid rgba(40,168,112,0.5);
  background:rgba(255,255,255,0.08);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
#ud-user-avatar { width:100%;height:100%;object-fit:cover;display:none; }
#ud-avatar-placeholder { font-size:1rem;opacity:0.5;line-height:1; }
#ud-user-name {
  font-size:0.78rem;font-weight:800;
  color:rgba(255,255,255,0.85);
  white-space:nowrap;max-width:120px;
  overflow:hidden;text-overflow:ellipsis;
  line-height:1;
}

#ud-spacer { flex: 1; }

#ud-nav { display: flex; gap: 5px; flex-shrink: 0; flex-wrap: wrap; justify-content: flex-end; }

.ud-btn {
  font-family: 'Nunito', sans-serif;
  font-size: 10px; font-weight: 700;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.09);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: var(--radius-sm);
  padding: 6px 10px;
  cursor: pointer;
  white-space: nowrap;
  transition: var(--transition);
}
.ud-btn:hover, .ud-btn.active {
  background: var(--green-400);
  border-color: var(--green-300);
  color: #fff;
  transform: translateY(-1px);
}

/* ═══════════════════════════════════════════════════
   SHARED UTILITIES
═══════════════════════════════════════════════════ */
.page { display: none !important; width: 100%; min-height: 100vh; }
.page.active { display: block !important; }
/* Restore flex layout for pages that use it */
#page-landing.active,
#page-vocab.active,
#page-sentences.active,
#page-convo.active,
#page-test.active { display: flex !important; }

.with-dash { padding-top: var(--dash-h); }

/* Space for fixed bottom nav strip on all inner pages */
#page-day1, #page-vocab, #page-sentences, #page-practice,
#page-convo, #page-test, #page-assess, #page-challenge {
  padding-bottom: 72px;
}

/* ═══════════════════════════════════════════════════
   PAGE 0 — LANDING
═══════════════════════════════════════════════════ */
#page-landing {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: #6BBF6B;
  padding: 2rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
#page-landing::before {
  content:'';
  position:absolute; inset:0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 30px 30px;
  pointer-events:none;
}

.landing-badge {
  display: inline-block;
  background: rgba(244,208,63,0.12);
  border: 1px solid rgba(244,208,63,0.35);
  color: var(--gold);
  font-size: 0.72rem; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 6px 16px; border-radius: var(--radius-pill);
  margin-bottom: 1.5rem;
}

.landing-title-wrap {
  margin-bottom: 1.6rem;
  text-align: center;
}
.landing-title-main {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.7rem, 5vw, 3rem);
  font-weight: 800;
  color: var(--green-900);
  letter-spacing: -0.5px;
  line-height: 1.12;
  text-shadow: 0 2px 8px rgba(0,0,0,0.12);
  margin-bottom: 0.55rem;
}
.landing-title-by {
  font-family: 'Cinzel', serif;
  font-style: normal;
  font-size: clamp(0.9rem, 2.2vw, 1.1rem);
  color: var(--green-700);
  font-weight: 600;
  letter-spacing: 2px;
}

.landing-sub {
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: rgba(255,255,255,0.72);
  max-width: 480px; margin: 0 auto 2.5rem;
  line-height: 1.7;
}

.landing-features {
  display: flex; flex-wrap: wrap; gap: 1rem;
  justify-content: center; margin-bottom: 2.5rem;
}
.feat-chip {
  background: rgba(40,168,112,0.15);
  border: 1px solid rgba(40,168,112,0.3);
  color: var(--green-100);
  font-size: 0.8rem; font-weight: 700;
  padding: 7px 15px; border-radius: var(--radius-pill);
}

#startBtn {
  padding: 1.1rem 3.5rem;
  font-family: 'Cinzel', serif;
  font-size: 1.1rem; font-weight: 800;
  color: var(--green-900);
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  border: none; border-radius: var(--radius-pill);
  cursor: pointer;
  box-shadow: 0 8px 32px rgba(244,208,63,0.38);
  transition: var(--transition);
  letter-spacing: .5px;
}
#startBtn:hover { transform: scale(1.06); box-shadow: 0 12px 40px rgba(244,208,63,0.5); }

.landing-wa {
  margin-top: 2rem;
  font-size: 0.8rem; color: rgba(255,255,255,0.4);
}
.landing-wa a { color: #25d366; text-decoration: none; font-weight: 700; }

/* ═══════════════════════════════════════════════════
   PAGE 1 — COURSE INDEX (60-day grid)
═══════════════════════════════════════════════════ */
#page-course {
  background: #6BBF6B;
}

.course-inner { max-width: 940px; margin: 0 auto; padding: 1.5rem; }

.course-welcome {
  text-align: center;
  padding: 1.2rem 0 0.6rem;
}
.course-welcome-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1rem, 3.5vw, 1.5rem);
  font-weight: 800;
  color: var(--green-900);
  letter-spacing: .5px;
  margin-bottom: 1.1rem;
  text-shadow: 0 1px 4px rgba(0,0,0,0.1);
}
.course-progress-wrap {
  max-width: 100%;
  margin: 0 auto 1.5rem;
}
.course-progress-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 7px;
}
.course-progress-label {
  font-size: 0.75rem; font-weight: 800;
  color: var(--green-100);
  letter-spacing: .3px;
}
.course-progress-count {
  font-size: 0.75rem; font-weight: 800;
  color: var(--gold-mid);
}
.course-progress-track {
  width: 100%; height: 10px;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-pill);
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
}
.course-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22883f 0%, #28a870 40%, #f4d03f 80%, #f59e0b 100%);
  border-radius: var(--radius-pill);
  transition: width 0.6s cubic-bezier(.4,0,.2,1);
  box-shadow: 0 0 10px rgba(244,208,63,0.3);
}

.weeks-nav {
  display: flex; flex-wrap: nowrap;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 4px;
}
.weeks-nav::-webkit-scrollbar { display: none; }
.week-pill {
  padding: 0.38rem 0.9rem;
  border-radius: var(--radius-pill);
  border: 1px solid rgba(40,168,112,0.35);
  background: transparent;
  color: var(--green-100);
  font-family: 'Nunito', sans-serif;
  font-size: 0.72rem; font-weight: 800;
  cursor: pointer; transition: var(--transition);
}
.week-pill:hover, .week-pill.active { background: var(--green-400); border-color: var(--green-300); color: #fff; }

.week-label {
  grid-column: 1/-1;
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem; color: var(--gold);
  margin: 1rem 0 0.5rem;
  border-left: 4px solid var(--green-400);
  padding-left: 10px;
  display: none;
}
.week-label.visible { display: block; }

.days-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.day-card, .weekly-review {
  background: rgba(20,90,50,0.42);
  border: 1px solid rgba(40,168,112,0.2);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: var(--transition);
  display: none;
  min-height: 64px;
}
.day-card.visible, .weekly-review.visible { display: block; }
.day-card:hover { border-color: var(--gold-mid); background: rgba(30,132,73,0.28); transform: translateY(-2px); }
.weekly-review:hover { border-color: var(--green-300); background: rgba(40,168,112,0.2); transform: translateY(-2px); }

.day-header {
  display: flex; align-items: center;
  gap: 0.8rem; padding: 0.8rem;
}
.day-badge, .week-badge {
  background: var(--green-400);
  min-width: 42px; height: 42px;
  border-radius: var(--radius-sm);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  font-size: 0.48rem; font-weight: 800; color: #fff;
  flex-shrink: 0;
}
.week-badge { background: var(--gold-mid); }
.day-badge strong, .week-badge strong { font-size: 1.05rem; }
.day-topic, .review-topic {
  font-size: 0.82rem; font-weight: 700;
  line-height: 1.25; text-align: left;
}

.course-footer {
  text-align: center; padding: 3rem 2rem;
  background: #061710;
  border-top: 1px solid rgba(40,168,112,0.12);
}
.wa-highlight {
  display: inline-block;
  background: #25d366; color: white;
  padding: 9px 22px; border-radius: var(--radius-pill);
  font-weight: 800; margin-bottom: 12px;
  text-decoration: none;
  box-shadow: 0 4px 18px rgba(37,211,102,0.3);
  transition: var(--transition);
}
.wa-highlight:hover { transform: scale(1.04); }

/* ═══════════════════════════════════════════════════
   PAGE 2 — DAY 1 INTRO
═══════════════════════════════════════════════════ */
#page-day1 {
  background: #6BBF6B;
  color: var(--text-dark);
}
#page-day1 main {
  min-height: calc(100vh - var(--dash-h) - 80px);
  display: flex; align-items: center; justify-content: center;
  padding: 24px 20px 36px;
}
.intro-card {
  background: #fff;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  max-width: 680px; width: 100%;
  padding: 44px 52px 48px;
  text-align: center;
  position: relative; overflow: hidden;
  animation: cardIn 0.7s cubic-bezier(.4,0,.2,1) both;
}
@keyframes cardIn {
  from { opacity:0; transform: translateY(28px) scale(0.98); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}
.intro-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:5px;
  background: linear-gradient(90deg, var(--green-400), var(--green-200), var(--green-400));
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}
.intro-card h1 {
  font-size: 28px; font-weight: 900;
  color: var(--text-dark); line-height: 1.3;
  margin-bottom: 8px; letter-spacing: -0.02em;
}
.intro-card h1 span { color: var(--green-500); }
.intro-divider {
  width: 60px; height: 4px;
  background: linear-gradient(90deg, var(--green-300), var(--green-200));
  border-radius: 99px; margin: 14px auto 26px;
}
.intro-body {
  font-size: 16px; line-height: 1.8;
  color: var(--text-mid); font-weight: 500;
  margin-bottom: 30px; text-align: left;
}
.intro-body ul { list-style: none; padding-left: 0; }
.intro-body li {
  margin-bottom: 12px; padding-left: 26px; position: relative;
}
.intro-body li::before {
  content:'✓'; position:absolute; left:0;
  color: var(--green-500); font-weight: 900;
}
.cta-btn {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg, var(--green-500) 0%, var(--green-400) 100%);
  color: #fff;
  font-family: 'Nunito', sans-serif;
  font-size: 16px; font-weight: 800;
  padding: 16px 40px; border-radius: var(--radius-pill);
  text-decoration: none; border: none; cursor: pointer;
  box-shadow: 0 6px 28px rgba(34,136,63,0.38);
  transition: var(--transition);
  letter-spacing: .3px;
}
.cta-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 36px rgba(34,136,63,0.48); }
.cta-btn svg { width: 18px; height: 18px; }
.intro-footer {
  text-align: center; padding: 18px 0 28px;
  font-size: 13px; color: var(--text-muted); font-weight: 600;
}
.intro-footer a { color: var(--green-600); text-decoration: none; font-weight: 800; display: block; margin-bottom: 6px; font-size: 15px; }

/* ═══════════════════════════════════════════════════
   PAGE 3 — VOCABULARY (Flashcards)
═══════════════════════════════════════════════════ */
#page-vocab {
  background: #6BBF6B;
  padding-top: var(--dash-h);
  padding-bottom: 44px;
  display: flex; flex-direction: column; align-items: center;
  position: relative; overflow-x: hidden;
}
#page-vocab::before {
  content:''; position:absolute; inset:0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 28px 28px; pointer-events:none; z-index:0;
}

.v-header { width:100%; max-width:660px; text-align:center; z-index:1; margin-bottom:20px; padding-top:20px; }
.v-header h2 {
  font-family: 'Cinzel', serif;
  font-size: 1.35rem; color: var(--green-900); letter-spacing: .5px; font-weight: 800;
}

.v-card {
  width:100%; max-width:660px;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(18px);
  border: 1px solid rgba(255,255,255,0.16);
  border-radius: var(--radius-xl);
  padding: 30px 28px 28px;
  box-shadow: var(--shadow-md);
  z-index:1;
  display: flex; flex-direction: column; align-items: center;
}

.progress-wrap { width:100%; margin-bottom:20px; }
.progress-label { display:flex; justify-content:space-between; font-size:0.75rem; color:var(--green-100); margin-bottom:8px; font-weight:800; }
.progress-bar  { width:100%; height:6px; background:rgba(255,255,255,0.1); border-radius:10px; overflow:hidden; }
.progress-fill { height:100%; background:linear-gradient(90deg,var(--green-300),var(--gold)); transition:width .4s ease; }

.flashcard-scene { width:100%; perspective:1100px; margin-bottom:22px; }
.flashcard {
  width:100%; min-height:230px;
  border-radius: var(--radius-lg);
  transform-style: preserve-3d;
  transition: transform .55s ease;
  cursor: pointer; position: relative;
}
.flashcard.flipped { transform: rotateY(180deg); }
.card-face {
  position:absolute; inset:0;
  border-radius: var(--radius-lg);
  backface-visibility: hidden;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 28px 24px; text-align: center;
}
.card-front { border:1.5px solid rgba(255,255,255,0.16); }
.card-front::before {
  content:''; position:absolute; inset:0;
  background: var(--card-gradient, linear-gradient(135deg,#134e2a,#166534));
  border-radius: inherit; z-index:0;
}
.card-front > * { position:relative; z-index:1; }
.card-back {
  background: linear-gradient(135deg,#0b3f23 0%,#155f36 100%);
  border: 1.5px solid rgba(255,255,255,0.12);
  transform: rotateY(180deg);
}
.card-word {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.5rem, 5vw, 2.4rem); font-weight: 700; color:#fff;
}
.card-urdu {
  margin-top:10px;
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: clamp(1.1rem, 4vw, 1.55rem);
  color: var(--green-100); direction: rtl; line-height:2.1;
}
.flip-hint { font-size:0.68rem; color:rgba(255,255,255,0.45); margin-top:8px; font-weight:600; }

.nav-row { display:flex; gap:12px; width:100%; margin-bottom:20px; }
.nav-btn-card {
  flex:1; padding:13px;
  border-radius: var(--radius-md);
  background: rgba(255,255,255,0.07);
  color:#fff; border:1.5px solid rgba(255,255,255,0.16);
  cursor:pointer; font-weight:800; font-family:'Nunito',sans-serif;
  transition: var(--transition);
}
.nav-btn-card:hover:not(:disabled) { background:rgba(40,168,112,0.3); }
.nav-btn-card:disabled { opacity:0.3; cursor:not-allowed; }

.bottom-actions { display:flex; gap:12px; width:100%; max-width:660px; margin-top:20px; flex-wrap:wrap; }
.btn-next-sec {
  display:inline-flex; align-items:center; justify-content:center; gap:10px;
  padding: 13px 22px; border-radius: var(--radius-pill);
  font-weight:800; text-decoration:none; transition:var(--transition);
  cursor:pointer; border:none; font-size:0.9rem; flex:1; min-width:150px;
  font-family:'Nunito',sans-serif;
}
.btn-gold { background:linear-gradient(135deg,var(--gold),#f59e0b); color:var(--green-900); box-shadow:0 5px 20px rgba(244,208,63,0.3); }
.btn-glass { background:rgba(255,255,255,0.09); border:1.5px solid rgba(255,255,255,0.28); color:#fff; }
.btn-next-sec:hover { transform:translateY(-3px); }

.page-footer { margin-top:28px; text-align:center; color:rgba(183,228,199,0.3); font-size:0.75rem; z-index:1; }

/* ── Vocab Start Overlay ── */
.v-start-overlay {
  position: absolute; inset: 0; z-index: 10;
  display: flex; align-items: center; justify-content: center;
  background: rgba(6,23,16,0.72);
  backdrop-filter: blur(6px);
  border-radius: var(--radius-lg);
}
.v-start-btn {
  font-family: 'Cinzel', serif;
  font-size: 1rem; font-weight: 700;
  color: var(--green-900);
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  border: none; border-radius: var(--radius-pill);
  padding: 13px 38px;
  cursor: pointer;
  box-shadow: 0 8px 32px rgba(244,208,63,0.4);
  transition: var(--transition);
  letter-spacing: 1px;
}
.v-start-btn:hover { transform: scale(1.07); box-shadow: 0 12px 40px rgba(244,208,63,0.55); }

/* ═══════════════════════════════════════════════════
   PAGE 4 — SENTENCES / PHRASES
═══════════════════════════════════════════════════ */
#page-sentences {
  background: #6BBF6B;
  padding-top: var(--dash-h);
  display: flex; flex-direction: column; align-items: center;
}

.s-main { width:100%; max-width:860px; padding:20px 16px 44px; display:flex; flex-direction:column; align-items:center; gap:20px; }
.s-title { font-family:'Cinzel', serif; font-size:1.5rem; color:var(--green-900); text-align:center; font-weight:800; letter-spacing:.5px; }

.s-card {
  width:100%;
  background: linear-gradient(160deg, #176044 0%, #0f4832 50%, #0a3427 100%);
  border: 1px solid rgba(40,168,112,0.22);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  padding: 30px 25px;
  display:flex; flex-direction:column; align-items:center; gap:18px;
}

.counter-bar {
  display:flex; align-items:center; justify-content:space-between; width:100%;
}
.counter-text { font-size:0.75rem; color:var(--green-100); font-weight:700; }
.progress-track { flex:1; height:4px; background:rgba(255,255,255,0.08); border-radius:4px; margin:0 12px; overflow:hidden; }
.cat-tag {
  font-size:0.68rem; text-transform:uppercase; letter-spacing:.1em;
  color:var(--gold-mid); background:rgba(200,168,75,0.1);
  padding:2px 10px; border-radius:10px; border:1px solid rgba(200,168,75,0.2);
}

.s-flashcard {
  width:100%; min-height:160px;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:12px; text-align:center; transition:opacity .25s ease;
}
.s-flashcard.animating { opacity:0; }
.phrase-en { font-family:'Playfair Display',serif; font-size:1.8rem; color:var(--gold); line-height:1.2; font-weight:700; }
.phrase-ur { font-family:'Noto Nastaliq Urdu',serif; direction:rtl; font-size:1.35rem; line-height:2.2; color:#fff; }

.s-nav-btns { display:flex; gap:10px; width:100%; justify-content:center; flex-wrap:wrap; }
.s-btn {
  font-family:'Nunito',sans-serif; font-size:0.8rem; font-weight:700;
  border:none; border-radius:var(--radius-pill); padding:10px 20px; cursor:pointer; transition:var(--transition);
}
.s-btn-outline { background:transparent; border:1.2px solid rgba(40,168,112,0.4); color:var(--green-50); }
.s-btn-primary { background:var(--green-400); color:#fff; }
.s-btn-speak { background:var(--gold-mid); color:var(--green-900); }
.s-btn:hover { transform:translateY(-2px); }

.s-links { display:flex; gap:12px; width:100%; justify-content:center; }
.s-link-btn {
  flex:1; max-width:180px;
  text-decoration:none; text-align:center;
  padding:12px; border-radius:var(--radius-md);
  font-weight:700; font-size:0.85rem; transition:var(--transition);
  cursor:pointer;
}
.sl-vocab { background:rgba(200,168,75,0.1); border:1px solid var(--gold-mid); color:var(--gold); }
.sl-prac  { background:rgba(40,168,112,0.1); border:1px solid var(--green-400); color:var(--green-100); }
.s-link-btn:hover { transform:translateY(-2px); }

/* ── Sentences Start Overlay ── */
.s-start-overlay {
  position: absolute; inset: 0; z-index: 10;
  display: flex; align-items: center; justify-content: center;
  background: rgba(8,31,22,0.82);
  backdrop-filter: blur(6px);
  border-radius: var(--radius-xl);
}
.s-start-btn {
  font-family: 'Cinzel', serif;
  font-size: 1rem; font-weight: 700;
  color: var(--green-900);
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  border: none; border-radius: var(--radius-pill);
  padding: 13px 36px;
  cursor: pointer;
  box-shadow: 0 8px 32px rgba(244,208,63,0.4);
  transition: var(--transition);
  letter-spacing: 1px;
}
.s-start-btn:hover { transform: scale(1.07); box-shadow: 0 12px 40px rgba(244,208,63,0.55); }

/* ═══════════════════════════════════════════════════
   PAGE 5 — SHADOWING PRACTICE (Teleprompter)
═══════════════════════════════════════════════════ */
#page-practice {
  background: #6BBF6B;
  color: var(--text-dark);
  padding-top: var(--dash-h);
  padding-bottom: 56px;
}

.p-section-title {
  font-family: 'Cinzel', serif;
  font-size: 1.4rem; font-weight: 800;
  color: var(--green-900);
  text-align: center;
  margin-bottom: 14px;
  letter-spacing: 0.5px;
}
.p-play-btn {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--green-500), var(--green-400));
  border: none;
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(34,136,63,0.4);
  transition: transform 0.15s, box-shadow 0.15s;
  flex-shrink: 0;
}
.p-play-btn:hover { transform: scale(1.1); box-shadow: 0 6px 22px rgba(34,136,63,0.55); }
.p-play-btn.playing { background: linear-gradient(135deg, #c0392b, #e74c3c); box-shadow: 0 4px 16px rgba(192,57,43,0.4); }

.p-wrap { max-width: 820px; margin: 0 auto; padding: 20px 14px 0; }
.p-card {
  background: #fff;
  border-radius: var(--radius-xl);
  box-shadow: 0 6px 30px rgba(26,71,49,0.14);
  padding: 22px 18px;
  border: 1.5px solid rgba(64,145,108,0.12);
}

.teleprompter {
  background: #1a4731;
  border-radius: var(--radius-lg);
  height: 280px;
  position: relative; overflow: hidden;
  margin-bottom: 20px;
  border: 3px solid #40916c;
}
.tp-highlight {
  position:absolute; left:10px; right:10px; top:50%; transform:translateY(-50%);
  height:64px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: var(--radius-md);
  pointer-events:none; z-index:2;
}
.tp-track {
  position:absolute; inset:0;
  overflow-y: scroll; scrollbar-width:none; z-index:4;
}
.tp-track::-webkit-scrollbar { display:none; }

.tp-row {
  height:64px; display:flex; align-items:center;
  justify-content:center; padding:0 15px;
  opacity:0.3; transition:0.3s; text-align:center;
  cursor: pointer;
}
.tp-row.active { opacity:1; }
.tp-text { font-size:0.84rem; font-weight:700; color:#fff; line-height:1.2; display:block; width:100%; }
.tp-row.active .tp-text { font-size:1.05rem; font-weight:900; text-shadow:0 2px 4px rgba(0,0,0,0.3); }

.tp-urdu {
  font-family:'Noto Nastaliq Urdu',serif; font-weight:700; font-size:1.2rem;
  color:var(--text-dark); text-align:center; direction:rtl; line-height:1.8;
  min-height:64px; margin-bottom:18px; padding:0 10px;
}
.chunk-nav { display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:18px; }
.chunk-btn {
  background:var(--green-100); border:none; padding:10px 18px;
  border-radius:10px; font-weight:800; color:var(--text-dark); cursor:pointer; font-size:0.9rem;
}
.chunk-btn:disabled { opacity:0.4; }

.p-start-overlay {
  position:absolute; inset:0; background:rgba(26,71,49,0.95);
  display:flex; align-items:center; justify-content:center; z-index:10;
}
.p-start-btn {
  background:#fff; color:#1a4731;
  padding:12px 24px; border-radius:30px;
  border:none; font-weight:900; cursor:pointer; font-size:0.9rem;
}

.p-action-row { display:flex; flex-direction:column; gap:10px; }
.p-action-btn {
  background:var(--green-400); color:#fff; padding:14px;
  border-radius:var(--radius-md); text-decoration:none;
  font-weight:800; text-align:center; font-size:0.95rem; cursor:pointer;
  transition:var(--transition);
}
.p-action-btn:hover { background:var(--green-500); }
.p-action-btn.alt { background:#2d6a4f; }

/* ═══════════════════════════════════════════════════
   PAGE 6 — CONVERSATION (Chat Phone UI)
═══════════════════════════════════════════════════ */
#page-convo {
  background: #6BBF6B;
  padding-top: var(--dash-h);
  display: flex; flex-direction: column; align-items: center;
  overflow-x: hidden;
}

.c-main { width:100%; max-width:600px; padding:0 12px 40px; display:flex; flex-direction:column; align-items:center; margin-top:20px; }

.c-topic { font-family:'Cinzel', serif; font-size:1.6rem; color:var(--green-900); margin-bottom:14px; letter-spacing:.05em; font-weight:800; }

.c-progress-wrap { width:100%; height:8px; background:rgba(255,255,255,0.1); border-radius:10px; margin-bottom:24px; overflow:hidden; border:1px solid rgba(40,168,112,0.2); }
.c-progress-fill { height:100%; background:linear-gradient(90deg,var(--gold-mid),var(--gold)); width:0%; transition:width .4s ease; }

.phone-wrapper { position:relative; width:100%; display:flex; justify-content:center; align-items:center; margin-bottom:28px; }
.mobile-phone {
  width:100%; max-width:318px; height:580px;
  background: #081f16;
  border: 8px solid #2a2a2a;
  border-radius: 40px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.6), inset 0 0 10px rgba(0,0,0,0.5);
  position:relative; overflow:hidden;
  display:flex; flex-direction:column; z-index:5;
}
.phone-nav-btn {
  position:absolute; top:50%; transform:translateY(-50%);
  width:48px; height:48px;
  background:var(--green-400); border:none; border-radius:50%;
  color:white; display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:var(--transition);
  box-shadow:0 6px 15px rgba(0,0,0,0.4); z-index:10;
}
.phone-nav-btn:disabled { opacity:0; pointer-events:none; }
.phone-nav-btn:hover { background:var(--green-300); transform:translateY(-50%) scale(1.1); }
#c-prevBtn { left:-10px; }
#c-nextBtn { right:-10px; }
@media(min-width:500px){ #c-prevBtn{left:40px;} #c-nextBtn{right:40px;} }

.phone-notch { position:absolute; top:0; left:50%; transform:translateX(-50%); width:150px; height:24px; background:#2a2a2a; border-bottom-left-radius:20px; border-bottom-right-radius:20px; z-index:10; }
.status-bar { height:44px; padding:0 24px; display:flex; justify-content:space-between; align-items:center; font-size:0.72rem; font-weight:700; color:#fff; z-index:5; margin-top:5px; }
.chat-head { padding:10px 18px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; gap:10px; }
.ch-avatar { width:34px; height:34px; background:var(--green-700); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.95rem; border:1px solid var(--green-400); }
.ch-info h4 { font-size:0.82rem; color:#fff; }
.ch-info p  { font-size:0.62rem; color:var(--green-300); }

.chat-window { flex:1; padding:18px 14px; display:flex; flex-direction:column; gap:18px; background:rgba(255,255,255,0.02); position:relative; overflow:hidden; }
.start-overlay { position:absolute; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; z-index:30; background:rgba(0,0,0,0.2); }
.start-chat-btn { background:var(--gold); color:var(--green-900); padding:12px 28px; border-radius:var(--radius-pill); border:none; font-weight:900; cursor:pointer; }

.msg-row { display:flex; width:100%; }
.msg-row.left { justify-content:flex-start; }
.msg-row.right { justify-content:flex-end; }
.bubble {
  max-width:86%; padding:11px 15px;
  border-radius:18px; font-size:0.93rem; line-height:1.4;
  min-height:56px; display:flex; flex-direction:column; justify-content:center;
}
.left .bubble { background:var(--green-700); color:#fff; border-bottom-left-radius:4px; }
.right .bubble { background:var(--gold); color:#1a0f00; border-bottom-right-radius:4px; direction:ltr; text-align:left; }
.bubble .ur-sub { margin-top:4px; font-size:0.72rem; opacity:.85; font-family:'Noto Nastaliq Urdu',serif; direction:rtl; text-align:right; font-weight:700; }
.typing-dots { display:inline-flex; gap:4px; padding:5px 0; }
.typing-dots span { width:6px; height:6px; background:#fff; border-radius:50%; animation:wave 1.2s infinite ease-in-out; opacity:.6; }
.right .typing-dots span { background:#1a0f00; }
.typing-dots span:nth-child(2){animation-delay:.2s;} .typing-dots span:nth-child(3){animation-delay:.4s;}
@keyframes wave { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-6px)} }
.fade-in { animation:fadeInMsg .5s ease forwards; opacity:0; }
@keyframes fadeInMsg { from{opacity:0;transform:translateY(5px)} to{opacity:1;transform:translateY(0)} }

.chat-input-bar { padding:14px; display:flex; align-items:center; gap:8px; border-top:1px solid rgba(255,255,255,0.05); }
.fake-input { flex:1; height:36px; background:rgba(255,255,255,0.1); border-radius:18px; padding:0 14px; display:flex; align-items:center; color:rgba(255,255,255,0.4); font-size:0.78rem; }
.mic-btn { width:36px; height:36px; background:var(--green-400); border-radius:50%; display:flex; align-items:center; justify-content:center; }

.c-wave-anim {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  padding: 18px 0 10px;
}
.c-wave-anim span {
  display: inline-block;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--gold);
  animation: chatWave 1.0s infinite ease-in-out;
  opacity: 0.85;
}
.c-wave-anim span:nth-child(1) { animation-delay: 0s; }
.c-wave-anim span:nth-child(2) { animation-delay: 0.12s; }
.c-wave-anim span:nth-child(3) { animation-delay: 0.24s; }
.c-wave-anim span:nth-child(4) { animation-delay: 0.36s; }
.c-wave-anim span:nth-child(5) { animation-delay: 0.48s; }
@keyframes chatWave {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.6; }
  30% { transform: translateY(-10px); opacity: 1; }
}


.c-action-btn { flex:1; text-decoration:none; background:rgba(200,168,75,0.14); border:1.5px solid var(--gold-mid); color:var(--gold); padding:12px; border-radius:var(--radius-pill); font-weight:800; text-align:center; font-size:0.85rem; cursor:pointer; transition:var(--transition); }
.c-action-btn:hover { background:rgba(200,168,75,0.25); }

/* ═══════════════════════════════════════════════════
   PAGE 7 — SPEAKING TEST
═══════════════════════════════════════════════════ */
#page-test {
  background: #6BBF6B;
  padding-top: var(--dash-h);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.t-container { width:96%; max-width:750px; padding-bottom:50px; margin-top:24px; }
.t-section-label { font-family:'Cinzel', serif; font-size:1.8rem; color:var(--green-900); text-align:center; margin-bottom:10px; font-weight:800; letter-spacing:.5px; }
.t-instruction { text-align:center; color:var(--green-50); font-size:1rem; margin-bottom:14px; font-weight:600; }
.t-progress-wrap { width:100%; height:18px; background:rgba(255,255,255,0.1); border-radius:12px; margin-bottom:24px; overflow:hidden; position:relative; border:1px solid rgba(255,255,255,0.1); }
.t-progress-fill { height:100%; background:linear-gradient(90deg,#28a870,#c8a84b,#f0d98a); width:0%; transition:width .4s ease; }
.t-progress-text { position:absolute; width:100%; text-align:center; font-size:0.68rem; line-height:18px; font-weight:800; color:#fff; text-shadow:0 1px 2px rgba(0,0,0,0.5); }

.t-card {
  background: linear-gradient(165deg,#145c42 0%,#0d3b2e 100%);
  border:1px solid rgba(40,168,112,0.22);
  border-radius:var(--radius-xl);
  box-shadow:var(--shadow-md);
  padding:26px 30px; text-align:center;
  min-height:320px; display:flex; flex-direction:column; gap:10px; position:relative;
}
.t-start-screen { flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center; gap:20px; }
.t-content { display:none; flex-direction:column; gap:10px; flex:1; justify-content:center; align-items:center; }
.t-congrats { display:none; flex-direction:column; justify-content:center; align-items:center; gap:14px; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:100%; animation:congratsIn .8s ease forwards; }
@keyframes congratsIn { from{opacity:0;transform:translate(-50%,-60%)} to{opacity:1;transform:translate(-50%,-50%)} }
.congrats-title { font-family:'Playfair Display',serif; font-size:2.4rem; color:var(--gold); }
.congrats-sub { font-size:1.15rem; color:#fff; }

.t-question { cursor:pointer; padding:8px; }
.t-q-text { font-size:1.75rem; font-weight:800; color:#fff; }
.t-reveal { display:none; flex-direction:column; gap:14px; margin-top:4px; animation:fadeInMsg .4s ease; }
.t-answer-box { padding:12px; border-bottom:1px solid rgba(200,168,75,0.2); }
.t-a-text { font-size:1.35rem; font-weight:700; color:var(--gold); }

.t-ctrl { display:flex; justify-content:center; align-items:center; gap:12px; padding-top:14px; margin-top:auto; }
.t-nav-btn { background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; padding:10px 15px; border-radius:var(--radius-md); cursor:pointer; font-weight:700; font-size:0.85rem; flex:1; max-width:100px; font-family:'Nunito',sans-serif; }
.t-show-btn, .t-start-btn { background:var(--gold); color:#1a0f00; border:none; padding:12px 26px; border-radius:var(--radius-pill); font-weight:900; cursor:pointer; box-shadow:0 4px 15px rgba(0,0,0,0.2); transition:var(--transition); font-family:'Nunito',sans-serif; }
.t-start-btn { font-size:1.1rem; padding:18px 42px; }
.t-show-btn { flex:2; max-width:165px; font-size:0.9rem; }
.t-nav-btn:disabled { opacity:0.3; }
.t-nav-btn:hover:not(:disabled), .t-show-btn:hover, .t-start-btn:hover { transform:translateY(-1px); }

.t-lesson-group { display:flex; gap:10px; margin-top:20px; }
.t-lesson-link { text-decoration:none; flex:1; background:var(--green-400); color:#fff; padding:14px; border-radius:var(--radius-lg); font-weight:900; text-align:center; font-size:0.95rem; transition:var(--transition); cursor:pointer; }
.t-lesson-link:hover { background:var(--green-500); }

/* ═══════════════════════════════════════════════════
   PAGE 8 — CHALLENGE
═══════════════════════════════════════════════════ */
#page-challenge {
  background: #6BBF6B;
  color: var(--text-dark);
}
#page-challenge main { min-height:calc(100vh - var(--dash-h) - 80px); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:24px 20px 36px; }

/* ═══════════════════════════════════════════════════
   PAGE 9 — ASSESSMENT (Quiz)
═══════════════════════════════════════════════════ */
#page-assess {
  background: #6BBF6B;
  color: var(--text-dark);
  padding-top: var(--dash-h);
  padding-bottom: 40px;
}
.a-wrap { max-width:700px; margin:0 auto; padding:16px 10px; }
.a-card { background:#fff; border-radius:var(--radius-lg); box-shadow:0 4px 20px rgba(26,71,49,0.1); padding:16px; border:1px solid rgba(0,0,0,0.05); }
.a-section-title { background:var(--green-100); color:var(--text-dark); padding:8px; border-radius:8px; margin:24px 0 12px; font-weight:900; text-align:center; font-size:0.84rem; text-transform:uppercase; letter-spacing:1px; }
.a-q-box { margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #f0f0f0; }
.a-q-row { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; }
.a-q-text { font-weight:900; font-size:1rem; color:var(--text-dark); }
.a-opt-row { display:flex; gap:6px; flex-wrap:wrap; margin-top:6px; }
.a-opt-btn { background:#fff; border:1.5px solid var(--green-100); padding:5px 10px; border-radius:8px; cursor:pointer; font-weight:800; font-size:0.84rem; transition:var(--transition); font-family:'Nunito',sans-serif; }
.a-opt-btn:hover { background:#f0fdf4; }
.a-opt-btn.correct { background:#d4edda !important; border-color:#28a745 !important; color:#155724; }
.a-opt-btn.wrong   { background:#f8d7da !important; border-color:#dc3545 !important; color:#721c24; }
.a-urdu { font-family:'Noto Nastaliq Urdu',serif; font-size:0.78rem; font-weight:500; line-height:1.6; }
.a-conv-line { font-size:0.93rem; font-weight:800; color:var(--green-600); margin-bottom:6px; }
