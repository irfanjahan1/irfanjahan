function weeksUpdateArrows() {
  var nav = document.getElementById('weeksNav');
  var lBtn = document.getElementById('weeks-scroll-left');
  var rBtn = document.getElementById('weeks-scroll-right');
  if (!nav || !lBtn || !rBtn) return;
  var overflow = nav.scrollWidth > nav.clientWidth + 4;
  var showLeft = overflow && nav.scrollLeft > 4;
  var showRight = overflow && nav.scrollLeft < nav.scrollWidth - nav.clientWidth - 4;
  lBtn.style.display = showLeft ? 'flex' : 'none';
  rBtn.style.display = showRight ? 'flex' : 'none';
}

