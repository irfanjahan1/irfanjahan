}
.v-start-btn:hover { transform: scale(1.07); box-shadow: 0 12px 40px rgba(244,208,63,0.55); }

/* ═══════════════════════════════════════════════════
   PAGE 4 — SENTENCES / PHRASES
═══════════════════════════════════════════════════ */
