let cIdx=0, cStarted=false;
const cTyping=`<div class="typing-dots"><span></span><span></span><span></span></div>`;

function cStart(){
  document.getElementById('c-overlay').style.display='none';
  // Show wavy animation immediately
  document.getElementById('c-wave-container').style.display='block';
  cStarted=true;
  document.getElementById('c-nextBtn').disabled=false;
  document.getElementById('c-prevBtn').style.visibility='visible';
  document.getElementById('c-nextBtn').style.visibility='visible';
