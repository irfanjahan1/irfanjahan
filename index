/* ─── COURSE PROGRESS ─────────────────────────────── */
let daysCompleted = 2;
function updateCourseProgress() {
  const total = 60;
  const pct = Math.min((daysCompleted / total) * 100, 100);
  const fill = document.getElementById('course-prog-fill');
  const count = document.getElementById('course-prog-count');
  if (fill) fill.style.width = pct + '%';
  if (count) count.textContent = daysCompleted + ' / ' + total + ' Days';
}

function challengeGenerateImage() {
  document.getElementById('ch-header-marks').textContent = 'Quiz Marks: ' + aScore;
  document.getElementById('ch-header-day').textContent   = 'Day ' + daysCompleted + ': Writing Task';
  const resultsDiv = document.getElementById('challenge-results-content');
  resultsDiv.innerHTML = '';
  const paraText = (document.getElementById('cq-para').value || '').trim();
  const para = document.createElement('p');
  para.style.cssText = "margin:0;font-size:0.82rem;font-weight:500;color:#1a1a1a;line-height:1.7;text-align:left;white-space:pre-wrap;word-break:break-word;";
  para.textContent = paraText || '—';
  resultsDiv.appendChild(para);
  const area = document.getElementById('challenge-capture-area');
  // Increment course progress
  if (daysCompleted < 60) { daysCompleted++; updateCourseProgress(); }
  html2canvas(area, {
    scale: 3,
    useCORS: true,
    logging: false,
    backgroundColor: null
  }).then(canvas => {
    const link = document.createElement('a');
    link.download = 'Day2_Writing_Task.png';
    link.href = canvas.toDataURL("image/png");
    link.click();
  });
}

