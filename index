let vIdx=0, vFlipped=false, vStarted=false;

function vStart() {
  vStarted = true;
  document.getElementById('v-start-overlay').style.display = 'none';
  document.getElementById('v-start-main-btn').style.display = 'none';
  document.getElementById('v-prev').style.visibility = 'visible';
  document.getElementById('v-next').style.visibility = 'visible';
  speak(vocab[vIdx].word);
}

function vRender(idx) {
  const v=vocab[idx];
  document.getElementById('v-word').textContent=v.word;
  document.getElementById('v-word-back').textContent=v.word;
  document.getElementById('v-urdu').textContent=v.urdu;
  document.getElementById('v-card-front').style.setProperty('--card-gradient', vGradients[idx%3]);
  document.getElementById('v-prog-text').textContent=`${idx+1} / ${vocab.length}`;
  document.getElementById('v-prog-fill').style.width=`${((idx+1)/vocab.length)*100}%`;
  document.getElementById('v-prev').disabled = idx===0;
  const vNextBtn = document.getElementById('v-next');
  if (idx === vocab.length - 1) {
    vNextBtn.disabled = false;
    vNextBtn.textContent = 'Next ▶';
    vNextBtn.onclick = () => { showPage('sentences'); };
    document.getElementById('v-restart-btn').style.display = '';
  } else {
    vNextBtn.disabled = false;
    vNextBtn.textContent = 'Next ▶';
    vNextBtn.onclick = vNext;
    document.getElementById('v-restart-btn').style.display = 'none';
  }
  if (vStarted) setTimeout(()=>speak(v.word),300);
}

document.getElementById('v-flashcard').addEventListener('click',()=>{
  if (!vStarted) return;
  if (!vFlipped) {
    // First tap: reveal meaning
    vFlipped = true;
    document.getElementById('v-flashcard').classList.add('flipped');
    setTimeout(()=>speak(vocab[vIdx].urdu.split('/')[0].trim(),'ur-PK'),300);
  } else {
    // Second tap: advance to next word (meaning hidden on new card)
    vNext();
  }
});
function vNext(){if(vIdx<vocab.length-1){vIdx++;vFlipped=false;document.getElementById('v-flashcard').classList.remove('flipped');vRender(vIdx);}}
function vPrev(){if(vIdx>0){vIdx--;vFlipped=false;document.getElementById('v-flashcard').classList.remove('flipped');vRender(vIdx);}}
function vRestart(){
  vIdx=0; vFlipped=false; vStarted=true;
  document.getElementById('v-flashcard').classList.remove('flipped');
  document.getElementById('v-restart-btn').style.display='none';
  vRender(0);
}
