const synth = window.speechSynthesis;
function speak(text, lang='en-US', rate=0.9) {
  synth.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = lang; u.rate = rate;
  const voices = synth.getVoices();
  if (lang.includes('ur')) u.voice = voices.find(v=>v.lang.includes('ur')) || voices[0];
  else u.voice = voices.find(v=>v.lang.includes('en') && v.name.includes('Google')) || voices[0];
  synth.speak(u);
}

