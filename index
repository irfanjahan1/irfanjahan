let cIdx=0, cStarted=false;
const cTyping=`<div class="typing-dots"><span></span><span></span><span></span></div>`;

function cStart(){
  document.getElementById('c-overlay').style.display='none';
  // Show wavy animation immediately
  document.getElementById('c-wave-container').style.display='block';
  cStarted=true;
  document.getElementById('c-nextBtn').disabled=false;
  document.getElementById('c-prevBtn').style.visibility='visible';
  document.getElementById('c-nextBtn').style.visibility='visible';
  cRender();
}
function cStep(d){cIdx+=d;cRender();}
function cRender(){
  const item=convo[cIdx];
  const qEn=document.getElementById('c-q-en'), qUr=document.getElementById('c-q-ur');
  const rEn=document.getElementById('c-r-en'), rUr=document.getElementById('c-r-ur');
  const rBub=document.getElementById('c-r-bubble');
  const qRow=document.getElementById('c-q-row');
  [qEn,qUr,rEn,rUr].forEach(el=>el.classList.remove('fade-in'));
  rBub.style.display='none';
  qRow.style.display='none';
  document.getElementById('c-wave-container').style.display='block';
  qEn.innerHTML=cTyping; qUr.innerHTML=''; rEn.innerHTML=''; rUr.innerHTML='';
  document.getElementById('c-prog').style.width=`${((cIdx+1)/convo.length)*100}%`;
  document.getElementById('c-prevBtn').disabled=cIdx===0;
  document.getElementById('c-nextBtn').disabled=cIdx===convo.length-1;
  cSpeak(item);
}
function cSpeak(item){
  synth.cancel();
  const qu=new SpeechSynthesisUtterance(item.qe), ru=new SpeechSynthesisUtterance(item.re);
  const voices=synth.getVoices();
  qu.voice=voices.find(v=>v.lang.startsWith('en')&&(v.name.includes('Female')||v.name.includes('Zira')||v.name.includes('Google UK English Female')||v.name.includes('Samantha')))||voices.find(v=>v.lang.startsWith('en'))||voices[0];
  ru.voice=voices.find(v=>v.lang.startsWith('en')&&(v.name.includes('Male')||v.name.includes('David')||v.name.includes('Google UK English Male')||v.name.includes('Daniel')))||voices.find(v=>v.lang.startsWith('en')&&v!==qu.voice)||voices[0];
  qu.rate=ru.rate=0.85;
  setTimeout(()=>{
    // Hide wave, show bubble
    document.getElementById('c-wave-container').style.display='none';
    document.getElementById('c-q-row').style.display='flex';
    document.getElementById('c-q-en').innerHTML=item.qe; document.getElementById('c-q-en').classList.add('fade-in');
    document.getElementById('c-q-ur').innerHTML=item.qu; document.getElementById('c-q-ur').classList.add('fade-in');
    synth.speak(qu);
  },600);
  qu.onend=()=>{
    const rb=document.getElementById('c-r-bubble'); rb.style.display='flex';
    document.getElementById('c-r-en').innerHTML=item.re; document.getElementById('c-r-en').classList.add('fade-in');
    document.getElementById('c-r-ur').innerHTML=item.ru; document.getElementById('c-r-ur').classList.add('fade-in');
    synth.speak(ru);
  };
}

