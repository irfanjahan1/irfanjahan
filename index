let aScore=0;
// Fill-in-the-blank state: selectedWord per paragraph
const aFillState = {}; // keyed by para index: {selectedBank: wordIdx|null, blanks: [filledWord|null,...]}

function aBuild(){
  document.getElementById('a-vocab-sec').innerHTML='';
  document.getElementById('a-trans-sec').innerHTML='';
  document.getElementById('a-conv-sec').innerHTML='';

  // Section 1: MCQ Vocabulary
  aVocab.forEach((d,i)=>{
    document.getElementById('a-vocab-sec').innerHTML+=`
    <div class="a-q-box" id="av-${i}">
      <div class="a-q-row">
        <span class="a-q-text">${i+1}. ${d.q}</span>
      </div>
      <div class="a-opt-row">${d.opts.map((o,idx)=>`<button class="a-opt-btn a-urdu" onclick="aChk(this,${idx},${d.c},'av-${i}')">${o}</button>`).join('')}</div>
    </div>`;
  });

  // Section 2: MCQ Translation
  aTrans.forEach((d,i)=>{
    document.getElementById('a-trans-sec').innerHTML+=`
    <div class="a-q-box" id="at-${i}">
      <span class="a-q-text a-urdu" style="display:block;margin-bottom:8px;font-size:1rem;">${i+1}. ${d.q}</span>
      <div class="a-opt-row">${d.opts.map((o,idx)=>`<button class="a-opt-btn" onclick="aChk(this,${idx},${d.c},'at-${i}')">${o}</button>`).join('')}</div>
    </div>`;
  });

  // Section 3: Fill in the Blanks
  aConv.forEach((d,i)=>{
    aFillState[i] = {selectedBank: null, blanks: new Array(d.answers.length).fill(null)};
    // Build paragraph HTML with clickable blanks
    let paraHTML = d.template.replace(/\((\d+)\)__________/g, (match, num)=>{
      const bIdx = parseInt(num)-1;
      return `(${num})<span class="a-blank" id="afb-${i}-${bIdx}" onclick="aFillBlank(${i},${bIdx})">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>`;
    });
    const bankHTML = d.bank.map((w,wi)=>`<button class="a-bank-word" id="afbw-${i}-${wi}" onclick="aSelectWord(${i},${wi},'${w}')">${w}</button>`).join('');
    document.getElementById('a-conv-sec').innerHTML+=`
    <div class="a-fill-box" id="afp-${i}">
      <div class="a-fill-title">📝 ${d.para}</div>
      <div style="margin-bottom:6px;font-size:0.75rem;font-weight:700;color:var(--text-muted);letter-spacing:.5px;">WORD BANK</div>
      <div class="a-word-bank">${bankHTML}</div>
      <div class="a-para-text">${paraHTML}</div>
    </div>`;
  });
}

// Select a word from the bank
window.aSelectWord = function(paraIdx, wordIdx, word) {
  const state = aFillState[paraIdx];
  // Deselect previous
  if (state.selectedBank !== null) {
    const prev = document.getElementById(`afbw-${paraIdx}-${state.selectedBank}`);
    if(prev) prev.classList.remove('selected');
  }
  // If clicking same word again — deselect
  if (state.selectedBank === wordIdx) { state.selectedBank = null; return; }
  state.selectedBank = wordIdx;
  const btn = document.getElementById(`afbw-${paraIdx}-${wordIdx}`);
  if(btn) btn.classList.add('selected');
};

// Click a blank to fill it
window.aFillBlank = function(paraIdx, blankIdx) {
  const state = aFillState[paraIdx];
  const blankEl = document.getElementById(`afb-${paraIdx}-${blankIdx}`);
  // If blank already filled — clear it
  if (state.blanks[blankIdx] !== null) {
    // Re-enable the bank word that was used here
    const usedWord = state.blanks[blankIdx];
    const d = aConv[paraIdx];
    const wi = d.bank.indexOf(usedWord);
    if(wi>=0){ const bw=document.getElementById(`afbw-${paraIdx}-${wi}`); if(bw){bw.classList.remove('used');bw.classList.remove('selected');}}
    state.blanks[blankIdx] = null;
    blankEl.textContent = '      ';
    blankEl.classList.remove('filled');
    if(state.selectedBank!==null){const sw=document.getElementById(`afbw-${paraIdx}-${state.selectedBank}`);if(sw)sw.classList.remove('selected');state.selectedBank=null;}
    return;
  }
  // No word selected — nothing to do
  if (state.selectedBank === null) return;
  const d = aConv[paraIdx];
  const word = d.bank[state.selectedBank];
  // Fill the blank
  state.blanks[blankIdx] = word;
  blankEl.textContent = word;
  blankEl.classList.add('filled');
  // Mark bank word as used
  const bw = document.getElementById(`afbw-${paraIdx}-${state.selectedBank}`);
  if(bw){ bw.classList.remove('selected'); bw.classList.add('used'); }
  state.selectedBank = null;
};

function aChk(btn,sel,cor,qid){
  const p=document.getElementById(qid);
  if(p.classList.contains('done'))return;
  p.classList.add('done');
  if(sel===cor){aScore++;btn.classList.add('correct');}
  else{btn.classList.add('wrong');p.querySelectorAll('.a-opt-btn')[cor].classList.add('correct');}
}

function aSubmit(){
  // Score fill-in-the-blank
  let fillScore = 0, fillTotal = 0;
  aConv.forEach((d,i)=>{
    const state = aFillState[i];
    d.answers.forEach((ans, bIdx)=>{
      fillTotal++;
      const blankEl = document.getElementById(`afb-${i}-${bIdx}`);
      const given = (state.blanks[bIdx]||'').toLowerCase().trim();
      if(given === ans.toLowerCase().trim()){
        fillScore++; aScore++;
        if(blankEl){blankEl.classList.add('correct-fill');}
      } else {
        if(blankEl){blankEl.classList.add('wrong-fill'); blankEl.title='Answer: '+ans;}
      }
      // Disable further interaction
      if(blankEl) blankEl.onclick=null;
    });
    // Disable bank words
    d.bank.forEach((_,wi)=>{ const bw=document.getElementById(`afbw-${i}-${wi}`); if(bw)bw.onclick=null; });
  });

  document.getElementById('a-quiz').style.display='none';
  document.getElementById('a-result').style.display='block';
  document.getElementById('a-bottom-nav').style.display='flex';
  const total = aVocab.length + aTrans.length + fillTotal;
  document.getElementById('a-score').textContent=`${aScore}/${total}`;
  let r='';
  if(aScore===total)r="Perfect! You are a Master! 🌟";
  else if(aScore>=total*0.83)r="Excellent Work! Keep it up! 👏";
  else if(aScore>=total*0.67)r="Good Job! You\'re doing well. 👍";
  else if(aScore>=total*0.5)r="Keep Practicing! You\'re getting there. 💪";
  else r="Don\'t give up! Review the lessons and try again. 📚";
  document.getElementById('a-remarks').textContent=r;
  const end=Date.now()+3000;
  (function frame(){
    confetti({particleCount:3,angle:60,spread:55,origin:{x:0},colors:['#1a4731','#40916c','#b7e4c7']});
    confetti({particleCount:3,angle:120,spread:55,origin:{x:1},colors:['#1a4731','#40916c','#b7e4c7']});
    if(Date.now()<end)requestAnimationFrame(frame);
  }());
}

