}
.s-btn-outline { background:transparent; border:1.2px solid rgba(40,168,112,0.4); color:var(--green-50); }
.s-btn-primary { background:var(--green-400); color:#fff; }
.s-btn-speak { background:var(--gold-mid); color:var(--green-900); }
