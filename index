.tp-text { font-size:0.84rem; font-weight:700; color:#fff; line-height:1.2; display:block; width:100%; }
.tp-row.active .tp-text { font-size:1.05rem; font-weight:900; text-shadow:0 2px 4px rgba(0,0,0,0.3); }

.tp-urdu {
  font-family:'Noto Nastaliq Urdu',serif; font-weight:700; font-size:0.92rem;
