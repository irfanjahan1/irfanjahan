function showPage(id) {
  synth.cancel();
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const pg = document.getElementById('page-'+id);
  if (pg) pg.classList.add('active');

  const dash = document.getElementById('universal-dash');
  if (DASH_PAGES.includes(id)) { dash.classList.add('visible'); }
  else { dash.classList.remove('visible'); }

  // Update active dashboard button
  document.querySelectorAll('.ud-btn').forEach(b=>b.classList.remove('active'));
  if (NAV_MAP[id]) {
    const match = [...document.querySelectorAll('.ud-btn')].find(b=>b.textContent.toLowerCase().includes(id));
    if (match) match.classList.add('active');
  }

  // Update page nav strip
  pnUpdateStrip(id);

  window.scrollTo(0,0);
}

function gotoPage(id) {
  showPage(id);
}
function goHome() { showCourse(); buildCourse(); showWeek(1); }
