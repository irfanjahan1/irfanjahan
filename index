  width:100%;padding:13px 18px;
  border-radius:50px;border:1.5px solid rgba(40,168,112,0.5);
  background:rgba(255,255,255,0.9);
  color:#0d1f13;font-size:0.95rem;font-family:'Nunito',sans-serif;
  outline:none;text-align:center;
  transition:border-color 0.2s,box-shadow 0.2s;
  margin-bottom:14px;box-sizing:border-box;
}
.reg-field::placeholder{color:rgba(0,0,0,0.35);}
.reg-field:focus{border-color:rgba(40,168,112,0.75);box-shadow:0 0 0 3px rgba(40,168,112,0.13);}

/* ── Photo Upload Area ── */
.reg-photo-area {
  display:flex;flex-direction:column;align-items:center;gap:6px;
  margin-bottom:4px;
}
.reg-avatar-ring {
  width:88px;height:88px;border-radius:50%;
  border:2.5px dashed rgba(40,168,112,0.5);
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,0.05);
  overflow:hidden;position:relative;cursor:pointer;
  transition:border-color 0.2s,background 0.2s;
}
.reg-avatar-ring:hover{border-color:rgba(244,208,63,0.7);background:rgba(244,208,63,0.05);}
.reg-avatar-ring img{width:100%;height:100%;object-fit:cover;display:none;border-radius:50%;}
.reg-avatar-ring .avatar-placeholder{font-size:2rem;opacity:0.5;pointer-events:none;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);line-height:1;}
.reg-photo-btn {
  font-family:'Nunito',sans-serif;font-size:0.8rem;font-weight:700;
  color:#0d4a22;
  background:rgba(40,168,112,0.2);
  border:1px solid rgba(40,168,112,0.45);
  border-radius:50px;padding:8px 18px;cursor:pointer;
  transition:background 0.2s,color 0.2s;
}
.reg-photo-btn:hover{background:rgba(40,168,112,0.4);color:#fff;}

/* ── Crop Modal ── */
#crop-modal {
  position:fixed;inset:0;z-index:100001;
  background:rgba(0,0,0,0.88);
  display:none;flex-direction:column;align-items:center;justify-content:center;
  padding:20px;
}
#crop-modal.open{display:flex;}
.crop-box{
  background:#0d2b18;border:1px solid rgba(40,168,112,0.4);
  border-radius:24px;padding:30px 28px;
  max-width:380px;width:100%;text-align:center;
  box-shadow:0 20px 60px rgba(0,0,0,0.7);
}
.crop-title{font-family:'Cinzel',serif;color:#f4d03f;font-size:1rem;margin-bottom:18px;letter-spacing:.4px;}
.crop-stage{
  position:relative;width:260px;height:260px;margin:0 auto 18px;
  border-radius:50%;overflow:hidden;
  border:3px solid rgba(40,168,112,0.6);
  background:#061710;cursor:grab;user-select:none;
  touch-action:none;
}
.crop-stage:active{cursor:grabbing;}
#crop-img{
  position:absolute;transform-origin:center center;
  max-width:none;pointer-events:none;
  image-rendering:auto;
}
.crop-mask{
  position:absolute;inset:0;border-radius:50%;
  box-shadow:0 0 0 9999px rgba(0,0,0,0.6);pointer-events:none;
}
.crop-zoom-row{display:flex;align-items:center;gap:10px;margin-bottom:16px;justify-content:center;}
.crop-zoom-row label{color:rgba(255,255,255,0.6);font-size:0.78rem;font-weight:700;}
#crop-zoom{width:140px;accent-color:#28a870;}
.crop-actions{display:flex;gap:10px;justify-content:center;}
.crop-btn{
  font-family:'Nunito',sans-serif;font-size:0.88rem;font-weight:800;
  border:none;border-radius:50px;padding:11px 26px;cursor:pointer;transition:transform 0.15s;
}
.crop-btn:hover{transform:scale(1.04);}
.crop-confirm{background:linear-gradient(135deg,#28a870,#22883f);color:#fff;}
.crop-cancel{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.75);border:1px solid rgba(255,255,255,0.18);}

/* ── Create Account Button ── */
.reg-submit {
  width:100%;padding:14px;
  background:linear-gradient(135deg,#f4d03f,#d4ac0d);
  color:#061710;border:none;border-radius:50px;
  font-size:1rem;font-weight:900;cursor:pointer;
  font-family:'Cinzel',serif;letter-spacing:.5px;
  transition:transform 0.15s,box-shadow 0.15s;
  box-shadow:0 6px 20px rgba(244,208,63,0.35);
  margin-top:2px;
}
.reg-submit:hover{transform:scale(1.04);box-shadow:0 10px 30px rgba(244,208,63,0.48);}
.reg-err{color:#b91c1c;font-size:0.8rem;min-height:18px;margin-bottom:6px;}
.reg-prev-btn {
  display:inline-flex;align-items:center;gap:5px;
  background:transparent;border:1.5px solid rgba(40,168,112,0.45);
  color:#0d4a22;font-family:'Nunito',sans-serif;font-size:0.8rem;font-weight:700;
  border-radius:50px;padding:6px 14px;cursor:pointer;
  transition:background 0.2s;margin-bottom:14px;
}
.reg-prev-btn:hover{background:rgba(40,168,112,0.15);}

/* ── Photo Source Picker ── */
#photo-source-modal {
  position:fixed;inset:0;z-index:100002;
  background:rgba(0,0,0,0.75);
  display:none;align-items:center;justify-content:center;
  padding:20px;
}
#photo-source-modal.open{display:flex;}
.photo-source-box {
  background:#0d2b18;border:1px solid rgba(40,168,112,0.4);
  border-radius:22px;padding:28px 24px;
  max-width:300px;width:100%;text-align:center;
  box-shadow:0 20px 60px rgba(0,0,0,0.7);
}
.photo-source-title{font-family:'Cinzel',serif;color:#f4d03f;font-size:1rem;margin-bottom:22px;letter-spacing:.4px;}
.photo-source-btns{display:flex;gap:14px;justify-content:center;}
.photo-source-btn{
  flex:1;padding:16px 8px;border-radius:14px;border:none;cursor:pointer;
  font-family:'Nunito',sans-serif;font-weight:800;font-size:0.88rem;
  transition:transform 0.15s;
  display:flex;flex-direction:column;align-items:center;gap:6px;
}
.photo-source-btn:hover{transform:scale(1.05);}
.photo-source-btn span{font-size:2rem;line-height:1;}
.psb-camera{background:rgba(40,168,112,0.2);border:1.5px solid rgba(40,168,112,0.5) !important;color:#fff;}
.psb-gallery{background:rgba(244,208,63,0.15);border:1.5px solid rgba(244,208,63,0.4) !important;color:#fff;}
.photo-source-cancel{margin-top:16px;background:none;border:none;color:rgba(255,255,255,0.4);font-size:0.8rem;cursor:pointer;font-family:'Nunito',sans-serif;display:block;width:100%;}
.photo-source-cancel:hover{color:rgba(255,255,255,0.75);}

/* ── Avatar Dropdown ── */
#ud-user-avatar-wrap { cursor:pointer; }
#ud-avatar-dropdown {
  position:fixed;
  top:calc(var(--dash-h) + 8px);
  right:12px;
  background:#0a2e1a;
  border:1px solid rgba(40,168,112,0.35);
  border-radius:14px;
  padding:14px 16px;
  min-width:190px;
  box-shadow:0 8px 32px rgba(0,0,0,0.55);
  z-index:2000;
  display:none;
  flex-direction:column;
  gap:10px;
  animation:dropIn 0.18s ease;
}
@keyframes dropIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
#ud-avatar-dropdown.open{display:flex;}
#ud-dropdown-name{
  font-family:'Nunito',sans-serif;font-weight:800;font-size:0.95rem;
  color:#fff;text-align:center;padding-bottom:10px;
  border-bottom:1px solid rgba(40,168,112,0.25);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
#ud-logout-btn{
  background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);
  color:#fca5a5;border-radius:8px;padding:9px 12px;
  font-family:'Nunito',sans-serif;font-weight:800;font-size:0.85rem;
  cursor:pointer;text-align:center;transition:background 0.15s;width:100%;
}
#ud-logout-btn:hover{background:rgba(239,68,68,0.28);}
</style>

<div id="reg-gate">
  <div class="reg-box">
    <button class="reg-prev-btn" onclick="closeRegGate()">◀ Previous</button>
    <div class="reg-icon">📚</div>
    <h2 class="reg-title">English Mastery Course</h2>
    <p class="reg-sub">Create your account to begin</p>

    <input id="reg-name" class="reg-field" type="text" placeholder="Enter Your Name" autocomplete="off"/>
    <input id="reg-id"   class="reg-field" type="text" placeholder="Enter ID" autocomplete="off"/>
    <input id="reg-pwd"  class="reg-field" type="password" placeholder="Enter Password" autocomplete="off"/>

    <div class="reg-photo-area">
      <div class="reg-avatar-ring" id="reg-avatar-ring" onclick="regOpenCamera()">
        <img id="reg-avatar-preview" alt="Profile"/>
        <span class="avatar-placeholder" id="reg-avatar-placeholder">📷</span>
      </div>
      <button class="reg-photo-btn" onclick="regOpenCamera()">Upload / Take Profile Picture</button>
    </div>

    <div class="reg-err" id="reg-err"></div>
    <button class="reg-submit" onclick="regSubmit()">Create Account</button>
  </div>
</div>

<!-- ── Crop Modal ── -->
<div id="crop-modal">
  <div class="crop-box">
    <div class="crop-title">🖼️ Position Your Face</div>
    <div class="crop-stage" id="crop-stage">
      <img id="crop-img" alt=""/>
      <div class="crop-mask"></div>
    </div>
    <div class="crop-zoom-row">
      <label>Zoom</label>
      <input type="range" id="crop-zoom" min="0.5" max="3" step="0.01" value="1" oninput="cropApplyTransform()"/>
    </div>
    <div class="crop-actions">
      <button class="crop-btn crop-cancel" onclick="cropCancel()">Cancel</button>
      <button class="crop-btn crop-confirm" onclick="cropConfirm()">Use This Photo</button>
    </div>
  </div>
</div>
<input type="file" id="reg-file-gallery" accept="image/*" style="display:none" onchange="regHandleFile(event)"/>
<input type="file" id="reg-file-camera"  accept="image/*" capture="user" style="display:none" onchange="regHandleFile(event)"/>

<!-- ── Photo Source Picker ── -->
<div id="photo-source-modal">
  <div class="photo-source-box">
    <div class="photo-source-title">📷 Add Profile Photo</div>
    <div class="photo-source-btns">
      <button class="photo-source-btn psb-camera" onclick="pickCamera()">
        <span>📷</span>Camera
      </button>
      <button class="photo-source-btn psb-gallery" onclick="pickGallery()">
        <span>🖼️</span>Gallery
      </button>
    </div>
    <button class="photo-source-cancel" onclick="closeSourcePicker()">Cancel</button>
  </div>
</div>

<script>
(function(){
  /* ── state ── */
  var croppedDataURL = null;
  var cropScale = 1, cropX = 0, cropY = 0;
  var cropDragging = false, cropStartX, cropStartY, cropOriginX, cropOriginY;
  var CROP_SIZE = 260;

  /* ── photo source picker ── */
  window.regOpenCamera = function(){
    document.getElementById('photo-source-modal').classList.add('open');
  };

  window.pickCamera = function(){
    document.getElementById('photo-source-modal').classList.remove('open');
    document.getElementById('reg-file-camera').click();
  };

  window.pickGallery = function(){
    document.getElementById('photo-source-modal').classList.remove('open');
    document.getElementById('reg-file-gallery').click();
  };

  window.closeSourcePicker = function(){
    document.getElementById('photo-source-modal').classList.remove('open');
  };

  window.regHandleFile = function(e){
    var file = e.target.files[0];
    if(!file) return;
    var reader = new FileReader();
    reader.onload = function(ev){
      openCropModal(ev.target.result);
    };
    reader.readAsDataURL(file);
    e.target.value=''; // reset so same file can be re-selected
  };

  /* ── crop modal ── */
  function openCropModal(src){
    var img = document.getElementById('crop-img');
    img.src = src;
    img.onload = function(){
      // fit image initially so it fills the crop circle
      var ratio = CROP_SIZE / Math.min(img.naturalWidth, img.naturalHeight);
      cropScale = ratio;
      cropX = (CROP_SIZE - img.naturalWidth * cropScale) / 2;
      cropY = (CROP_SIZE - img.naturalHeight * cropScale) / 2;
      document.getElementById('crop-zoom').value = cropScale;
      document.getElementById('crop-zoom').min = ratio * 0.5;
      document.getElementById('crop-zoom').max = ratio * 4;
      document.getElementById('crop-zoom').step = ratio * 0.01;
      cropApplyTransform();
    };
    document.getElementById('crop-modal').classList.add('open');
  }

  window.cropApplyTransform = function(){
    var zoom = parseFloat(document.getElementById('crop-zoom').value);
    if(zoom !== cropScale){
      // zoom toward center
      var cx = CROP_SIZE/2, cy = CROP_SIZE/2;
      cropX = cx - (cx - cropX) * (zoom / cropScale);
      cropY = cy - (cy - cropY) * (zoom / cropScale);
      cropScale = zoom;
    }
    var img = document.getElementById('crop-img');
    img.style.width  = (img.naturalWidth  * cropScale) + 'px';
    img.style.height = (img.naturalHeight * cropScale) + 'px';
    img.style.left = cropX + 'px';
    img.style.top  = cropY + 'px';
  };

  /* drag to pan */
  var stage = document.getElementById('crop-stage');
  stage.addEventListener('mousedown', function(e){
    cropDragging=true; cropStartX=e.clientX; cropStartY=e.clientY;
    cropOriginX=cropX; cropOriginY=cropY; e.preventDefault();
  });
  document.addEventListener('mousemove', function(e){
    if(!cropDragging) return;
    cropX = cropOriginX + (e.clientX - cropStartX);
    cropY = cropOriginY + (e.clientY - cropStartY);
    cropApplyTransform();
  });
  document.addEventListener('mouseup', function(){ cropDragging=false; });

  stage.addEventListener('touchstart', function(e){
    cropDragging=true;
    cropStartX=e.touches[0].clientX; cropStartY=e.touches[0].clientY;
    cropOriginX=cropX; cropOriginY=cropY; e.preventDefault();
  },{passive:false});
  document.addEventListener('touchmove', function(e){
    if(!cropDragging) return;
    cropX = cropOriginX + (e.touches[0].clientX - cropStartX);
    cropY = cropOriginY + (e.touches[0].clientY - cropStartY);
    cropApplyTransform(); e.preventDefault();
  },{passive:false});
  document.addEventListener('touchend', function(){ cropDragging=false; });

  window.cropCancel = function(){
    document.getElementById('crop-modal').classList.remove('open');
  };

  window.cropConfirm = function(){
    // render the visible crop circle to a canvas
    var img = document.getElementById('crop-img');
    var canvas = document.createElement('canvas');
    canvas.width = CROP_SIZE; canvas.height = CROP_SIZE;
    var ctx = canvas.getContext('2d');
    ctx.beginPath(); ctx.arc(CROP_SIZE/2,CROP_SIZE/2,CROP_SIZE/2,0,Math.PI*2);
    ctx.clip();
    ctx.drawImage(img, cropX, cropY, img.naturalWidth*cropScale, img.naturalHeight*cropScale);
    croppedDataURL = canvas.toDataURL('image/png');

    // show preview
    var preview = document.getElementById('reg-avatar-preview');
    preview.src = croppedDataURL;
    preview.style.display = 'block';
    document.getElementById('reg-avatar-placeholder').style.display = 'none';

    document.getElementById('crop-modal').classList.remove('open');
  };

  /* ── form submit ── */
  window.regSubmit = function(){
    var name = document.getElementById('reg-name').value.trim();
    var id   = document.getElementById('reg-id').value.trim();
    var pwd  = document.getElementById('reg-pwd').value;
    var err  = document.getElementById('reg-err');

    if(!name){ err.textContent='Please enter your name.'; return; }
    if(!id)  { err.textContent='Please enter your ID.'; return; }
    if(pwd !== 'freedom'){ err.textContent='Incorrect password. Please try again.'; return; }

    err.textContent='';

    // ── embed user data into the page for all sections to use ──
    window.USER_NAME   = name;
    window.USER_ID     = id;
    window.USER_PHOTO  = croppedDataURL || null;

    // Update the universal dashboard avatar/name if elements exist
    var udName = document.getElementById('ud-user-name');
    var udAvatar = document.getElementById('ud-user-avatar');
    var udDropdownName = document.getElementById('ud-dropdown-name');
    if(udName) udName.textContent = name;
    if(udDropdownName) udDropdownName.textContent = '👤 ' + name;
    if(udAvatar && croppedDataURL){
      udAvatar.src = croppedDataURL;
      udAvatar.style.display = 'block';
      var udAvatarPlaceholder = document.getElementById('ud-avatar-placeholder');
      if(udAvatarPlaceholder) udAvatarPlaceholder.style.display = 'none';
    }

    // Populate any greeting elements across all pages
    document.querySelectorAll('.user-name-display').forEach(function(el){ el.textContent = name; });
    document.querySelectorAll('.user-id-display').forEach(function(el){ el.textContent = id; });
    document.querySelectorAll('.user-photo-display').forEach(function(el){
      if(croppedDataURL){ el.src = croppedDataURL; el.style.display='block'; }
    });

    // Dismiss gate
    var gate = document.getElementById('reg-gate');
    gate.style.transition='opacity 0.45s';
    gate.style.opacity='0';
    setTimeout(function(){
      gate.style.display='none';
      gate.style.opacity='';
      showCourse(); buildCourse(); showWeek(1);
    },450);
  };

  /* ── avatar dropdown ── */
  window.toggleAvatarDropdown = function(e){
    e.stopPropagation();
    var dd = document.getElementById('ud-avatar-dropdown');
    dd.classList.toggle('open');
  };

  document.addEventListener('click', function(){
    var dd = document.getElementById('ud-avatar-dropdown');
    if(dd) dd.classList.remove('open');
  });

  window.doLogout = function(){
    // Reload the page to return to registration
    location.reload();
  };

  /* ── landing start (no registration gate) ── */
  window.landingStart = function(){
    window.USER_NAME  = '';
    window.USER_ID    = '';
    window.USER_PHOTO = null;
    showCourse(); buildCourse(); showWeek(1);
  };

  /* ── reg-gate show/hide (kept for reference) ── */
  window.openRegGate = function(){
    var gate = document.getElementById('reg-gate');
    gate.style.display = 'flex';
    gate.style.opacity = '0';
    gate.style.transition = 'opacity 0.35s';
    setTimeout(function(){ gate.style.opacity = '1'; }, 20);
  };

  window.closeRegGate = function(){
    var gate = document.getElementById('reg-gate');
    gate.style.transition = 'opacity 0.3s';
    gate.style.opacity = '0';
    setTimeout(function(){ gate.style.display = 'none'; gate.style.opacity = ''; }, 320);
  };

  /* ── landing copy buttons ── */
  window.landingCopy = function(text, btn){
    navigator.clipboard.writeText(text).then(function(){
      var orig = btn.textContent;
      btn.textContent = '✓';
      setTimeout(function(){ btn.textContent = orig; }, 1500);
    });
  };

  /* ── course details popup ── */
  window.openDetailsPopup = function(){
    var modal = document.getElementById('course-details-modal');
    var scroller = document.getElementById('cdm-scroll');
    scroller.scrollTop = 0;
    cdmUpdateArrow();
    modal.classList.add('open');
  };
  window.closeDetailsPopup = function(){
    document.getElementById('course-details-modal').classList.remove('open');
  };
  document.getElementById('course-details-modal').addEventListener('click', function(e){
    if (e.target === this) closeDetailsPopup();
  });

  /* arrow scroll button */
  function cdmUpdateArrow() {
    var scroller = document.getElementById('cdm-scroll');
    var btn = document.getElementById('cdm-arrow-btn');
    var atBottom = scroller.scrollHeight - scroller.scrollTop - scroller.clientHeight < 10;
    btn.innerHTML = atBottom ? '&#8593;' : '&#8595;';
    btn.title = atBottom ? 'Scroll up' : 'Scroll down';
  }
  window.cdmScroll = function(){
    var scroller = document.getElementById('cdm-scroll');
    var atBottom = scroller.scrollHeight - scroller.scrollTop - scroller.clientHeight < 10;
    scroller.scrollBy({ top: atBottom ? -scroller.clientHeight * 0.75 : scroller.clientHeight * 0.75, behavior: 'smooth' });
    setTimeout(cdmUpdateArrow, 350);
  };
  document.getElementById('cdm-scroll').addEventListener('scroll', cdmUpdateArrow);

})();
</script>

</body>
